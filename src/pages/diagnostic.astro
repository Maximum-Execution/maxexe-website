---
import '../styles/global.css';
---
<html lang="en" data-theme="phosphor-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Business Diagnostic | MAXIMUM EXECUTION</title>
    <meta name="description" content="Free diagnostic tool. 5 minutes. Find out where your business is losing ground and what to build first." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href="https://maximumexecution.com/diagnostic/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#1a110a" />
    <link rel="preload" href="/fonts/GeistSans.woff2" as="font" type="font/woff2" crossorigin />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://maximumexecution.com/diagnostic/" />
    <meta property="og:title" content="Business Diagnostic | MAXIMUM EXECUTION" />
    <meta property="og:description" content="Free diagnostic tool. 5 minutes. Find out where your business is losing ground and what to build first." />
    <meta property="og:image" content="https://maximumexecution.com/og-image.png" />
    <meta property="og:site_name" content="MAXIMUM EXECUTION" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Business Diagnostic | MAXIMUM EXECUTION" />
    <meta name="twitter:description" content="Free diagnostic tool. 5 minutes. Find out where your business is losing ground and what to build first." />
    <meta name="twitter:image" content="https://maximumexecution.com/og-image.png" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "MAXIMUM EXECUTION",
      "url": "https://maximumexecution.com/",
      "description": "Free diagnostic tool. 5 minutes. Find out where your business is losing ground and what to build first.",
      "founder": { "@type": "Person", "name": "Spencer Bennett", "jobTitle": "Creative Technologist" },
      "address": { "@type": "PostalAddress", "addressLocality": "Richmond", "addressRegion": "VA", "addressCountry": "US" },
      "areaServed": "US",
      "serviceType": ["Web Design", "Web Development", "Custom Software Development"]
    })} />
  </head>
  <body class="min-h-screen bg-base-100 text-base-content">
    <main id="main-content">
      <div class="mx-auto max-w-4xl px-4 pt-4 sm:px-6 lg:px-8">
        <a href="/" class="inline-flex items-center gap-2 font-mono text-xs tracking-wider text-base-content/60 transition-colors duration-200 hover:text-primary">
          <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Back to home
        </a>
      </div>
      <section class="diagnostic-section relative min-h-dvh">
        <div class="pointer-events-none absolute inset-0 z-10" style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, oklch(0 0 0 / 0.03) 2px, oklch(0 0 0 / 0.03) 4px);" aria-hidden="true"></div>
        <div class="relative z-20 flex min-h-dvh items-center justify-center px-4 py-16">
          <div id="diagnostic-root" class="w-full max-w-2xl transition-opacity duration-150" role="region" aria-label="Business diagnostic assessment" aria-live="polite">
            <p class="font-mono text-sm text-phosphor-dim">[DIAGNOSTIC TOOL]</p>
            <p class="mt-2 text-base-content/60">Interactive assessment // loading...</p>
          </div>
        </div>
      </section>

      <script>
        // ============================================================
        // MAX.EXE Business Diagnostic Tool
        // State-machine driven assessment with branching paths
        // ============================================================

        // ------------------------------------------------------------
        // 1. QUESTION DEFINITIONS (scored questions only)
        // ------------------------------------------------------------
        const QUESTIONS = {
          W1: {
            dimension: "ONLINE PRESENCE",
            skipScore: 1,
            question: "A stranger lands on your homepage for the first time. In five seconds, can they tell exactly what you do, who it\u2019s for, and what to do next?",
            options: [
              { label: "Yes. People tell me the site is clear and they understood it immediately.", value: "A", score: 3 },
              { label: "Probably the general idea, but I\u2019m not sure they\u2019d know what to do next.", value: "B", score: 2 },
              { label: "Honestly, no. My homepage is more about who we are than what we do for the client.", value: "C", score: 1 },
            ],
          },
          W2: {
            dimension: "ONLINE PRESENCE",
            skipScore: 1,
            question: "In the last 90 days, how many real leads came from your website without you personally chasing them?",
            options: [
              { label: "Consistent inbound. My site generates qualified interest on its own.", value: "A", score: 3 },
              { label: "A few, but most business still comes from referrals or me reaching out personally.", value: "B", score: 2 },
              { label: "None I can point to. The site exists but doesn\u2019t bring in work.", value: "C", score: 1 },
            ],
          },
          W3: {
            dimension: "ONLINE PRESENCE",
            skipScore: 2,
            question: "When someone shows interest in your business, what happens next on your end?",
            options: [
              { label: "A documented system handles it. Automated follow-up, a lead magnet, a sequence. It runs without me.", value: "A", score: 3 },
              { label: "I follow up personally when I remember or when it feels urgent.", value: "B", score: 2 },
              { label: "Nothing formal. If they want to work with me, they\u2019ll reach out.", value: "C", score: 1 },
            ],
          },
          W4: {
            dimension: "ONLINE PRESENCE",
            skipScore: 2,
            question: "If you had to explain what your business does to a complete stranger in one sentence, how confident are you that they\u2019d immediately get it?",
            options: [
              { label: "Very confident. I have a clear, practiced one-liner that lands every time.", value: "A", score: 3 },
              { label: "I can explain it, but I usually ramble or get different reactions from different people.", value: "B", score: 2 },
              { label: "I struggle with this. It\u2019s hard to explain what makes us different.", value: "C", score: 1 },
            ],
          },
          S1a: {
            dimension: "OPERATIONS",
            skipScore: 1,
            question: "How much of the work you do every week is truly custom, and how much is the same pattern repeated?",
            options: [
              { label: "Almost everything we do follows a repeatable process. The exceptions are rare.", value: "A", score: 3 },
              { label: "There are patterns, but we still handle a lot of things manually or inconsistently.", value: "B", score: 2 },
              { label: "Every project feels different. There\u2019s no standard process.", value: "C", score: 1 },
            ],
          },
          S2a: {
            dimension: "OPERATIONS",
            skipScore: 1,
            question: "If you disappeared for two weeks, would the business keep running at the same quality?",
            options: [
              { label: "Yes. The systems and documentation are strong enough that my team or a substitute could manage.", value: "A", score: 3 },
              { label: "It would keep going, but quality would drop. Too many things depend on my judgment.", value: "B", score: 2 },
              { label: "It would stall or fail. I am the business.", value: "C", score: 1 },
            ],
          },
          S1b: {
            dimension: "OPERATIONS",
            skipScore: 1,
            question: "When a customer interacts with your business, how much of that experience is consistent and intentional?",
            options: [
              { label: "Very consistent. We\u2019ve mapped the customer journey and most touchpoints are designed.", value: "A", score: 3 },
              { label: "Somewhat consistent, but quality varies depending on who handles it or how busy we are.", value: "B", score: 2 },
              { label: "Not very. Every customer gets a slightly different experience.", value: "C", score: 1 },
            ],
          },
          S2b: {
            dimension: "OPERATIONS",
            skipScore: 1,
            question: "How do you currently handle customer requests, appointments, or service inquiries?",
            options: [
              { label: "Through a centralized system. Scheduling, intake, and communication flow through one tool.", value: "A", score: 3 },
              { label: "Through a mix of tools, emails, and phone calls. It works, but it\u2019s fragmented.", value: "B", score: 2 },
              { label: "Manually. People call or email and we handle it as it comes.", value: "C", score: 1 },
            ],
          },
          S1c: {
            dimension: "OPERATIONS",
            skipScore: 2,
            question: "When you need to know how the business is performing, how quickly can you get the answer?",
            options: [
              { label: "Instantly. We have dashboards or reports that show key metrics in real time.", value: "A", score: 3 },
              { label: "Within a day or two. I can pull the numbers but it takes some digging.", value: "B", score: 2 },
              { label: "I mostly go on gut feeling. The data isn\u2019t organized or easily accessible.", value: "C", score: 1 },
            ],
          },
          S2c: {
            dimension: "OPERATIONS",
            skipScore: 2,
            question: "How confident are you in the accuracy of the data you use to make business decisions?",
            options: [
              { label: "Very confident. Our data is clean, current, and comes from reliable sources.", value: "A", score: 3 },
              { label: "Somewhat confident, but I know there are gaps or things that aren\u2019t tracked well.", value: "B", score: 2 },
              { label: "Not confident. I\u2019m often guessing or working from outdated information.", value: "C", score: 1 },
            ],
          },
          S3: {
            dimension: "OPERATIONS",
            skipScore: 2,
            question: "What\u2019s your biggest frustration with how your business runs day-to-day?",
            options: [
              { label: "Honestly, things run pretty well. I\u2019m looking to optimize, not fix.", value: "A", score: 3 },
              { label: "There are a few bottlenecks that slow us down, but we manage.", value: "B", score: 2 },
              { label: "It\u2019s chaotic. Too many things depend on me remembering or following up.", value: "C", score: 1 },
            ],
          },
          WS1: {
            dimension: "COMBINED",
            skipScore: 2,
            question: "When you think about what\u2019s holding your business back the most right now, where does the pain sit?",
            options: [
              { label: "Getting found and attracting new business. The work is great \u2014 people just don\u2019t know we exist.", value: "A", score: 3 },
              { label: "Running the business efficiently. We\u2019re growing but the backend can\u2019t keep up.", value: "B", score: 2 },
              { label: "Both equally. We need to be visible AND organized.", value: "C", score: 1 },
            ],
          },
          AI2: {
            dimension: "AI READINESS",
            skipScore: 1,
            question: "How comfortable is your team with adopting new technology?",
            options: [
              { label: "Very comfortable. We try new tools regularly and adapt quickly.", value: "A", score: 3 },
              { label: "Somewhat comfortable, but we need guidance and time to adopt new systems.", value: "B", score: 2 },
              { label: "Resistant or hesitant. Change is hard for us.", value: "C", score: 1 },
            ],
          },
        };

        // Helper: route to AI module or Q1 based on AI interest
        function routeToAIOrQ1(state) {
          return state.aiInterest === "yes" || state.aiInterest === "maybe" ? "AI1" : "Q1";
        }

        // ------------------------------------------------------------
        // 2. SCREEN DEFINITIONS (routing logic)
        // ------------------------------------------------------------
        const SCREENS = {
          // --- Opening ---
          opening: {
            id: "opening",
            type: "splash",
            body: "Five minutes. A handful of honest answers. A clear picture of where your business stands and what to build first.",
            buttonLabel: "RUN THE DIAGNOSTIC",
            getNextScreen: () => "G1",
          },

          // --- Gateway ---
          G1: {
            id: "G1",
            type: "gateway",
            question: "What\u2019s the main focus of what you need?",
            options: [
              { label: "A website that actually brings in business.", value: "W" },
              { label: "Software or a system to run my business better.", value: "S" },
              { label: "Both. I need the online presence and the backend.", value: "WS" },
            ],
            getNextScreen: () => "G2",
          },
          G2: {
            id: "G2",
            type: "gateway",
            question: "Is AI or automation something you\u2019re interested in for your business?",
            options: [
              { label: "Yes. I want to use AI to save time or serve customers better.", value: "yes" },
              { label: "Maybe. I\u2019m curious but not sure where it fits.", value: "maybe" },
              { label: "Not right now. I just need the basics done well.", value: "no" },
            ],
            getNextScreen: (state) => {
              if (state.path === "W") return "W0";
              if (state.path === "S") return "S0";
              return "WS0";
            },
          },

          // --- Path W (Website) ---
          W0: {
            id: "W0",
            type: "routing",
            question: "Do you currently have a website for your business?",
            dimension: "ONLINE PRESENCE",
            options: [
              { label: "Yes, I have a website.", value: "A" },
              { label: "No, not yet.", value: "B" },
            ],
            getNextScreen: (_state, value) => (value === "B" ? "W0-skip" : "W1"),
          },
          "W0-skip": {
            id: "W0-skip",
            type: "routing",
            question: "// We\u2019ll score this section as if you\u2019re starting from scratch.",
            getNextScreen: () => "W4",
          },
          W1: { id: "W1", ...QUESTIONS.W1, type: "scored", getNextScreen: () => "W2" },
          W2: { id: "W2", ...QUESTIONS.W2, type: "scored", getNextScreen: () => "W3" },
          W3: { id: "W3", ...QUESTIONS.W3, type: "scored", getNextScreen: () => "W4" },
          W4: { id: "W4", ...QUESTIONS.W4, type: "scored", getNextScreen: (state) => routeToAIOrQ1(state) },

          // --- Path S (Software) ---
          S0: {
            id: "S0",
            type: "routing",
            question: "Which of these sounds most like your situation?",
            dimension: "OPERATIONS",
            options: [
              { label: "I need to streamline or automate internal processes.", value: "A" },
              { label: "I need a better system for managing customers or clients.", value: "B" },
              { label: "I need better data, reporting, or decision-making tools.", value: "C" },
            ],
            getNextScreen: (_state, value) => {
              if (value === "A") return "S1a";
              if (value === "B") return "S1b";
              return "S1c";
            },
          },
          S1a: { id: "S1a", ...QUESTIONS.S1a, type: "scored", getNextScreen: () => "S2a" },
          S2a: { id: "S2a", ...QUESTIONS.S2a, type: "scored", getNextScreen: () => "S3" },
          S1b: { id: "S1b", ...QUESTIONS.S1b, type: "scored", getNextScreen: () => "S2b" },
          S2b: { id: "S2b", ...QUESTIONS.S2b, type: "scored", getNextScreen: () => "S3" },
          S1c: { id: "S1c", ...QUESTIONS.S1c, type: "scored", getNextScreen: () => "S2c" },
          S2c: { id: "S2c", ...QUESTIONS.S2c, type: "scored", getNextScreen: () => "S3" },
          S3: { id: "S3", ...QUESTIONS.S3, type: "scored", getNextScreen: (state) => routeToAIOrQ1(state) },

          // --- Path WS (Both) ---
          WS0: {
            id: "WS0",
            type: "routing",
            question: "If you had to pick one to fix first, which would it be?",
            dimension: "COMBINED",
            options: [
              { label: "The website. I need to be found first.", value: "A" },
              { label: "The operations. Internal chaos is the bigger problem.", value: "B" },
              { label: "They\u2019re equally urgent. I need both.", value: "C" },
            ],
            getNextScreen: (_state, value) => {
              if (value === "A") return "WS-rA-W0";
              if (value === "B") return "WS-rB-S0";
              return "WS-rC-W0";
            },
          },

          // --- WS Route A: Website first, then Software ---
          "WS-rA-W0": {
            id: "WS-rA-W0",
            type: "routing",
            question: "Do you currently have a website for your business?",
            dimension: "ONLINE PRESENCE",
            options: [
              { label: "Yes, I have a website.", value: "A" },
              { label: "No, not yet.", value: "B" },
            ],
            getNextScreen: (_state, value) => (value === "B" ? "WS-rA-W0-skip" : "WS-rA-W1"),
          },
          "WS-rA-W0-skip": {
            id: "WS-rA-W0-skip",
            type: "routing",
            question: "// We\u2019ll score the website section as if you\u2019re starting from scratch.",
            getNextScreen: () => "WS-rA-W4",
          },
          "WS-rA-W1": { id: "WS-rA-W1", ...QUESTIONS.W1, type: "scored", getNextScreen: () => "WS-rA-W2" },
          "WS-rA-W2": { id: "WS-rA-W2", ...QUESTIONS.W2, type: "scored", getNextScreen: () => "WS-rA-W3" },
          "WS-rA-W3": { id: "WS-rA-W3", ...QUESTIONS.W3, type: "scored", getNextScreen: () => "WS-rA-W4" },
          "WS-rA-W4": { id: "WS-rA-W4", ...QUESTIONS.W4, type: "scored", getNextScreen: () => "WS-rA-S0" },
          "WS-rA-S0": {
            id: "WS-rA-S0",
            type: "routing",
            question: "Which of these sounds most like your situation?",
            dimension: "OPERATIONS",
            options: [
              { label: "I need to streamline or automate internal processes.", value: "A" },
              { label: "I need a better system for managing customers or clients.", value: "B" },
              { label: "I need better data, reporting, or decision-making tools.", value: "C" },
            ],
            getNextScreen: (_state, value) => {
              if (value === "A") return "WS-rA-S1a";
              if (value === "B") return "WS-rA-S1b";
              return "WS-rA-S1c";
            },
          },
          "WS-rA-S1a": { id: "WS-rA-S1a", ...QUESTIONS.S1a, type: "scored", getNextScreen: () => "WS-rA-S2a" },
          "WS-rA-S2a": { id: "WS-rA-S2a", ...QUESTIONS.S2a, type: "scored", getNextScreen: () => "WS-rA-S3" },
          "WS-rA-S1b": { id: "WS-rA-S1b", ...QUESTIONS.S1b, type: "scored", getNextScreen: () => "WS-rA-S2b" },
          "WS-rA-S2b": { id: "WS-rA-S2b", ...QUESTIONS.S2b, type: "scored", getNextScreen: () => "WS-rA-S3" },
          "WS-rA-S1c": { id: "WS-rA-S1c", ...QUESTIONS.S1c, type: "scored", getNextScreen: () => "WS-rA-S2c" },
          "WS-rA-S2c": { id: "WS-rA-S2c", ...QUESTIONS.S2c, type: "scored", getNextScreen: () => "WS-rA-S3" },
          "WS-rA-S3": { id: "WS-rA-S3", ...QUESTIONS.S3, type: "scored", getNextScreen: () => "WS1" },

          // --- WS Route B: Software first, then Website ---
          "WS-rB-S0": {
            id: "WS-rB-S0",
            type: "routing",
            question: "Which of these sounds most like your situation?",
            dimension: "OPERATIONS",
            options: [
              { label: "I need to streamline or automate internal processes.", value: "A" },
              { label: "I need a better system for managing customers or clients.", value: "B" },
              { label: "I need better data, reporting, or decision-making tools.", value: "C" },
            ],
            getNextScreen: (_state, value) => {
              if (value === "A") return "WS-rB-S1a";
              if (value === "B") return "WS-rB-S1b";
              return "WS-rB-S1c";
            },
          },
          "WS-rB-S1a": { id: "WS-rB-S1a", ...QUESTIONS.S1a, type: "scored", getNextScreen: () => "WS-rB-S2a" },
          "WS-rB-S2a": { id: "WS-rB-S2a", ...QUESTIONS.S2a, type: "scored", getNextScreen: () => "WS-rB-S3" },
          "WS-rB-S1b": { id: "WS-rB-S1b", ...QUESTIONS.S1b, type: "scored", getNextScreen: () => "WS-rB-S2b" },
          "WS-rB-S2b": { id: "WS-rB-S2b", ...QUESTIONS.S2b, type: "scored", getNextScreen: () => "WS-rB-S3" },
          "WS-rB-S1c": { id: "WS-rB-S1c", ...QUESTIONS.S1c, type: "scored", getNextScreen: () => "WS-rB-S2c" },
          "WS-rB-S2c": { id: "WS-rB-S2c", ...QUESTIONS.S2c, type: "scored", getNextScreen: () => "WS-rB-S3" },
          "WS-rB-S3": { id: "WS-rB-S3", ...QUESTIONS.S3, type: "scored", getNextScreen: () => "WS-rB-W0" },
          "WS-rB-W0": {
            id: "WS-rB-W0",
            type: "routing",
            question: "Do you currently have a website for your business?",
            dimension: "ONLINE PRESENCE",
            options: [
              { label: "Yes, I have a website.", value: "A" },
              { label: "No, not yet.", value: "B" },
            ],
            getNextScreen: (_state, value) => (value === "B" ? "WS-rB-W0-skip" : "WS-rB-W1"),
          },
          "WS-rB-W0-skip": {
            id: "WS-rB-W0-skip",
            type: "routing",
            question: "// We\u2019ll score the website section as if you\u2019re starting from scratch.",
            getNextScreen: () => "WS-rB-W4",
          },
          "WS-rB-W1": { id: "WS-rB-W1", ...QUESTIONS.W1, type: "scored", getNextScreen: () => "WS-rB-W2" },
          "WS-rB-W2": { id: "WS-rB-W2", ...QUESTIONS.W2, type: "scored", getNextScreen: () => "WS-rB-W3" },
          "WS-rB-W3": { id: "WS-rB-W3", ...QUESTIONS.W3, type: "scored", getNextScreen: () => "WS-rB-W4" },
          "WS-rB-W4": { id: "WS-rB-W4", ...QUESTIONS.W4, type: "scored", getNextScreen: () => "WS1" },

          // --- WS Route C: Equal priority (website then software) ---
          "WS-rC-W0": {
            id: "WS-rC-W0",
            type: "routing",
            question: "Do you currently have a website for your business?",
            dimension: "ONLINE PRESENCE",
            options: [
              { label: "Yes, I have a website.", value: "A" },
              { label: "No, not yet.", value: "B" },
            ],
            getNextScreen: (_state, value) => (value === "B" ? "WS-rC-W0-skip" : "WS-rC-W1"),
          },
          "WS-rC-W0-skip": {
            id: "WS-rC-W0-skip",
            type: "routing",
            question: "// We\u2019ll score the website section as if you\u2019re starting from scratch.",
            getNextScreen: () => "WS-rC-W4",
          },
          "WS-rC-W1": { id: "WS-rC-W1", ...QUESTIONS.W1, type: "scored", getNextScreen: () => "WS-rC-W2" },
          "WS-rC-W2": { id: "WS-rC-W2", ...QUESTIONS.W2, type: "scored", getNextScreen: () => "WS-rC-W3" },
          "WS-rC-W3": { id: "WS-rC-W3", ...QUESTIONS.W3, type: "scored", getNextScreen: () => "WS-rC-W4" },
          "WS-rC-W4": { id: "WS-rC-W4", ...QUESTIONS.W4, type: "scored", getNextScreen: () => "WS-rC-S0" },
          "WS-rC-S0": {
            id: "WS-rC-S0",
            type: "routing",
            question: "Which of these sounds most like your situation?",
            dimension: "OPERATIONS",
            options: [
              { label: "I need to streamline or automate internal processes.", value: "A" },
              { label: "I need a better system for managing customers or clients.", value: "B" },
              { label: "I need better data, reporting, or decision-making tools.", value: "C" },
            ],
            getNextScreen: (_state, value) => {
              if (value === "A") return "WS-rC-S1a";
              if (value === "B") return "WS-rC-S1b";
              return "WS-rC-S1c";
            },
          },
