        const AI_MODIFIERS = {
          "customer-facing": "You\u2019re interested in using AI to improve the customer experience. That\u2019s a high-impact area. We can build AI-powered tools that help your customers get faster answers, better recommendations, and a more personalized experience.",
          internal: "You\u2019re looking at AI to streamline internal operations. Smart move. We can build AI systems that automate repetitive tasks, surface insights from your data, and free up your time for higher-value work.",
          discovery: "You\u2019re curious about AI but not sure where it fits. That\u2019s exactly the right starting point. We\u2019ll identify the highest-impact AI opportunity based on your specific business and build a focused proof of concept.",
