        const W_TIERS = { 10: "high", 11: "high", 12: "high", 7: "mid", 8: "mid", 9: "mid", 4: "low", 5: "low", 6: "low", 0: "critical", 1: "critical", 2: "critical", 3: "critical" };
        const S_TIERS = { 8: "high", 9: "high", 5: "mid", 6: "mid", 7: "mid", 0: "low", 1: "low", 2: "low", 3: "low", 4: "low" };
        const W_MAX_SCORE = 12;
        const S_MAX_SCORE = 9;

