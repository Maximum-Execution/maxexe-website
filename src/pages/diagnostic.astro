        const SECONDARY_CTA_TEXT = "// We respond within 24 hours.";
        const SECONDARY_CTA = { label: "[ VIEW ALL SERVICES > ]", href: "/#services" };

        // ------------------------------------------------------------
        // 4. STATE MANAGEMENT
        // ------------------------------------------------------------
        function createState() {
          return {
            screen: "opening",
            path: null,
            subPath: null,
            aiInterest: null,
            wsPriority: null,
            answers: {},
            history: [],
            skipCount: 0,
            businessDescription: "",
            businessType: null,
            ultimateOutcome: "",
            contactName: "",
            contactEmail: "",
            contactCompany: "",
          };
        }

        // Routing helpers
        function pathFromG1(value) {
          return { W: "W", S: "S", WS: "WS" }[value] || null;
        }
        function aiFromG2(value) {
          return { yes: "yes", maybe: "maybe", no: "no" }[value] || null;
        }
        function subPathFromS0(value) {
          return { A: "a", B: "b", C: "c" }[value] || null;
        }
        function priorityFromWS0(value) {
          return { A: "A", B: "B", C: "C" }[value] || null;
        }
        function typeFromQ1Type(value) {
          return { A: "local-service", B: "ecommerce", C: "professional-services", D: "nonprofit" }[value] || "other";
        }

        // Check if screen ID is a "skip" screen that auto-advances
        function isSkipScreen(screenId) {
          return screenId === "W0-skip" || screenId.endsWith("-W0-skip");
        }

        // State machine reducer
        function reducer(state, action) {
          switch (action.type) {
            case "ANSWER": {
              const next = { ...state };
              next.answers = { ...next.answers, [action.screenId]: { value: action.value, score: action.score } };
              if (action.screenId === "G1") next.path = pathFromG1(action.value);
              if (action.screenId === "G2") next.aiInterest = aiFromG2(action.value);
              if (action.screenId === "S0" || action.screenId.endsWith("-S0")) next.subPath = subPathFromS0(action.value);
              if (action.screenId === "WS0") next.wsPriority = priorityFromWS0(action.value);
              if (action.screenId === "Q1-type") next.businessType = typeFromQ1Type(action.value);
              const screen = SCREENS[action.screenId];
              if (screen?.getNextScreen) next.screen = screen.getNextScreen(next, action.value);
              next.history = [...next.history, state.screen];
              return next;
            }
            case "SKIP": {
              const next = { ...state };
              next.answers = { ...next.answers, [action.screenId]: { value: "skip", score: action.skipScore } };
              next.skipCount = next.skipCount + 1;
              const screen = SCREENS[action.screenId];
              if (screen?.getNextScreen) next.screen = screen.getNextScreen(next);
              next.history = [...next.history, state.screen];
              return next;
            }
            case "TEXT_INPUT": {
              const next = { ...state };
              next.answers = { ...next.answers, [action.screenId]: { value: action.value } };
              if (action.screenId === "Q1") next.businessDescription = action.value;
              if (action.screenId === "Q4") next.ultimateOutcome = action.value;
              const screen = SCREENS[action.screenId];
              if (screen?.getNextScreen) next.screen = screen.getNextScreen(next);
              next.history = [...next.history, state.screen];
              return next;
            }
            case "EMAIL_SUBMIT": {
              const next = { ...state };
              next.contactName = action.name;
              next.contactEmail = action.email;
              if (action.company) next.contactCompany = action.company;
              const screen = SCREENS["email-gate"];
              if (screen?.getNextScreen) next.screen = screen.getNextScreen(next);
              next.history = [...next.history, state.screen];
              return next;
            }
            case "ADVANCE": {
              const next = { ...state };
              // W0-skip and WS variants: auto-score W1/W2/W3
              if (isSkipScreen(action.screenId)) {
                next.answers = {
                  ...next.answers,
                  W1: { value: "skip", score: 1 },
                  W2: { value: "skip", score: 1 },
                  W3: { value: "skip", score: 1 },
                };
                next.skipCount = next.skipCount + 3;
              }
              const screen = SCREENS[action.screenId];
              if (screen?.getNextScreen) next.screen = screen.getNextScreen(next);
              next.history = [...next.history, state.screen];
              return next;
            }
            case "BACK": {
              if (state.history.length === 0) return state;
              const next = { ...state };
              const prevScreen = next.history[next.history.length - 1];
              next.history = next.history.slice(0, -1);
              next.screen = prevScreen;
              return next;
            }
            default:
              return state;
          }
        }

        // ------------------------------------------------------------
        // 5. SCORING & ROUTING
        // ------------------------------------------------------------
        function calculatePathScore(state) {
          const wKeys = ["W1", "W2", "W3", "W4"];
          const sKeys = ["S1a", "S2a", "S1b", "S2b", "S1c", "S2c", "S3"];
          let score = 0;
          let max = 0;
          const keys = state.path === "W" ? wKeys : state.path === "S" ? sKeys : [...wKeys, ...sKeys];
          for (const key of keys) {
            const answer = state.answers[key];
            if (answer?.score != null) {
              score += answer.score;
              max += 3;
            }
          }
          return { score, max: max || (state.path === "W" ? W_MAX_SCORE : state.path === "S" ? S_MAX_SCORE : W_MAX_SCORE + S_MAX_SCORE) };
        }

        function splitWSScore(state) {
          let wScore = 0, wMax = 0, sScore = 0, sMax = 0;
          for (const key of ["W1", "W2", "W3", "W4"]) {
            const a = state.answers[key];
            if (a?.score != null) { wScore += a.score; wMax += 3; }
          }
          for (const key of ["S1a", "S2a", "S1b", "S2b", "S1c", "S2c", "S3"]) {
            const a = state.answers[key];
            if (a?.score != null) { sScore += a.score; sMax += 3; }
          }
          return { w: { score: wScore, max: wMax || W_MAX_SCORE }, s: { score: sScore, max: sMax || S_MAX_SCORE } };
        }

        function getTier(state) {
          const { score } = calculatePathScore(state);
          if (state.path === "W") return W_TIERS[score] || "low";
          if (state.path === "S") return S_TIERS[score] || "low";
          // WS: use combined score mapped to W tiers
          const combined = splitWSScore(state);
          const wTier = W_TIERS[combined.w.score] || "low";
          const sTier = S_TIERS[combined.s.score] || "low";
          const tierOrder = { critical: 0, low: 1, mid: 2, high: 3 };
          return tierOrder[wTier] < tierOrder[sTier] ? wTier : sTier;
        }

        function getFullResults(state) {
          const pathScore = calculatePathScore(state);
          const tier = getTier(state);
          let result;
          if (state.path === "W") {
            result = RESULTS_COPY.W[tier] || RESULTS_COPY.W.low;
          } else if (state.path === "S") {
            result = RESULTS_COPY.S[tier] || RESULTS_COPY.S.low;
          } else {
            result = { ...RESULTS_COPY.WS.default };
            const ws = splitWSScore(state);
            const primaryGap = ws.w.score <= ws.s.score ? "online presence" : "operations";
            result.body = result.body.replace("{primaryGap}", primaryGap);
          }

          // AI modifier
          let aiModifier = null;
          if (state.aiInterest === "yes" || state.aiInterest === "maybe") {
            const ai1 = state.answers.AI1?.value;
            const ai2 = state.answers.AI2?.value;
            if (ai2 === "C") {
              aiModifier = AI_MODIFIERS["low-readiness"];
            } else if (ai1 === "A") {
              aiModifier = AI_MODIFIERS.internal;
            } else if (ai1 === "B") {
              aiModifier = AI_MODIFIERS["customer-facing"];
            } else {
              aiModifier = AI_MODIFIERS.discovery;
            }
          }

          return { result, aiModifier, pathScore, tier };
        }

        function getRoutingOutcome(state) {
          const q2 = state.answers.Q2?.value;
          const q3 = state.answers.Q3?.value;
          if (q3 === "A" && (q2 === "A" || q2 === "B")) return "personal-outreach";
          if (q3 === "C" || q2 === "C") return "long-nurture";
          return "standard-nurture";
        }

        function calculateProgress(state) {
          const totalEstimate = state.path === "WS" ? 18 : 12;
          return Math.min(0.1 + (state.history.length / totalEstimate) * 0.9, 1);
        }

        // ------------------------------------------------------------
        // 6. DOM HELPERS
        // ------------------------------------------------------------
        let currentProgress = 0.1;

        function el(tag, className) {
          const element = document.createElement(tag);
          if (className) element.className = className;
          return element;
        }

        function primaryButton(label) {
          const btn = document.createElement("button");
          btn.className = "btn btn-primary font-mono font-bold tracking-wider uppercase border-2 border-primary hover:border-accent hover:bg-accent hover:text-accent-content text-base px-8 py-3";
          btn.type = "button";
          btn.textContent = `[ ${label} > ]`;
          return btn;
        }

        function primaryLink(label, href) {
          const link = document.createElement("a");
          link.className = "btn btn-primary font-mono font-bold tracking-wider uppercase border-2 border-primary hover:border-accent hover:bg-accent hover:text-accent-content text-base px-8 py-3";
          link.href = href;
          link.textContent = `[ ${label} > ]`;
          return link;
        }

        function letterLabel(index) {
          return String.fromCharCode(65 + index);
        }

        function prefersReducedMotion() {
          return window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        }

        function delay(ms) {
          return new Promise((resolve) => setTimeout(resolve, ms));
        }

        function pathDisplayName(path) {
          return path === "W" ? "ONLINE PRESENCE" : path === "S" ? "OPERATIONS" : "COMBINED";
        }

        function tierBadge(tier) {
          if (tier === "high") return { text: "[OK]", colorClass: "text-success" };
          if (tier === "mid") return { text: "[WARN]", colorClass: "text-warning" };
          return { text: "[ERR]", colorClass: "text-error" };
        }

        // ------------------------------------------------------------
        // 7. RENDERERS
        // ------------------------------------------------------------
        function renderSplash(screen, _state, dispatch) {
          const container = el("div");
          const heading = el("h2", "font-pixel text-3xl sm:text-4xl text-primary mb-6");
          heading.textContent = "BUSINESS DIAGNOSTIC_";
          container.appendChild(heading);
          if (screen.body) {
            const body = el("p", "text-base-content/80 leading-relaxed mb-8");
            body.textContent = screen.body;
            container.appendChild(body);
          }
          const btn = primaryButton(screen.buttonLabel || "BEGIN DIAGNOSTIC");
          btn.addEventListener("click", () => dispatch({ type: "ADVANCE", screenId: screen.id }));
          container.appendChild(btn);
          return container;
        }

        function renderQuestion(screen, state, dispatch) {
          const container = el("div");
          if (screen.dimension) {
            const dim = el("p", "font-mono text-xs tracking-wider text-phosphor-dim mb-2");
            dim.textContent = `// ${screen.dimension}`;
            container.appendChild(dim);
          }
          if (screen.question) {
            const q = el("h2", "text-xl sm:text-2xl font-bold leading-snug mb-8");
            q.textContent = screen.question;
            container.appendChild(q);
          }
          if (screen.options && screen.options.length > 0) {
            const group = el("div", "space-y-3");
            group.setAttribute("role", "radiogroup");
            if (screen.question) group.setAttribute("aria-label", screen.question);
            screen.options.forEach((opt, i) => {
              const btn = document.createElement("button");
              const isSelected = state.answers[screen.id]?.value === opt.value;
              btn.className = [
                "w-full text-left border-2 bg-base-200 p-4 font-mono text-sm leading-relaxed transition-colors duration-200 cursor-pointer",
                isSelected ? "border-primary" : "border-base-300",
                "hover:border-primary",
              ].join(" ");
              btn.type = "button";
              btn.setAttribute("role", "radio");
              btn.setAttribute("aria-checked", isSelected ? "true" : "false");
              btn.textContent = `${letterLabel(i)}) ${opt.label}`;
              btn.addEventListener("click", () => {
                group.querySelectorAll("button").forEach((b) => {
                  b.classList.remove("border-primary");
                  b.classList.add("border-base-300");
                });
                btn.classList.remove("border-base-300");
                btn.classList.add("border-primary");
                setTimeout(() => {
                  dispatch({ type: "ANSWER", screenId: screen.id, value: opt.value, score: opt.score });
                }, 300);
              });
              group.appendChild(btn);
            });
            container.appendChild(group);
          }
          if (screen.type === "scored" && screen.skipScore != null) {
            const skipWrap = el("div", "mt-6");
            const skipBtn = document.createElement("button");
            skipBtn.type = "button";
            skipBtn.className = "btn btn-ghost font-mono text-xs tracking-wider text-base-content/40 hover:text-base-content/60";
            skipBtn.textContent = "THIS DOESN\u2019T APPLY TO ME >";
            skipBtn.addEventListener("click", () => {
              skipBtn.textContent = "// Noted. Moving on.";
              setTimeout(() => dispatch({ type: "SKIP", screenId: screen.id, skipScore: screen.skipScore }), 600);
            });
            skipWrap.appendChild(skipBtn);
            container.appendChild(skipWrap);
          }
          return container;
        }

        function renderTextInput(screen, state, dispatch) {
          const container = el("div");
          if (screen.dimension) {
            const dim = el("p", "font-mono text-xs tracking-wider text-phosphor-dim mb-2");
            dim.textContent = `// ${screen.dimension}`;
            container.appendChild(dim);
          }
          if (screen.question) {
            const q = el("h2", "text-xl sm:text-2xl font-bold leading-snug mb-8");
            q.textContent = screen.question;
            container.appendChild(q);
          }
          const textarea = document.createElement("textarea");
          textarea.className = "textarea textarea-bordered w-full border-2 border-base-300 bg-base-200 font-mono text-sm focus:border-primary focus:outline-none";
          textarea.rows = 4;
          if (screen.question) textarea.setAttribute("aria-label", screen.question);
          if (screen.placeholder) textarea.placeholder = screen.placeholder;
          const existing = state.answers[screen.id]?.value;
          if (existing) textarea.value = existing;
          container.appendChild(textarea);
          const btnWrap = el("div", "mt-6");
          const btn = primaryButton(screen.buttonLabel || "CONTINUE");
          btn.addEventListener("click", () => dispatch({ type: "TEXT_INPUT", screenId: screen.id, value: textarea.value }));
          btnWrap.appendChild(btn);
          container.appendChild(btnWrap);
          return container;
        }

        function renderEmailGate(screen, state, dispatch) {
          const container = el("div");
          const heading = el("h2", "text-xl sm:text-2xl font-bold leading-snug mb-4");
          heading.textContent = "Enter your email to see your full results.";
          container.appendChild(heading);
          const hint = el("p", "font-mono text-sm text-phosphor-dim mb-8");
          hint.textContent = "// We don\u2019t send noise. One follow-up based on your score.";
          container.appendChild(hint);

          const form = el("div", "space-y-4");

          // Name field
          const nameWrap = el("div");
          const nameLabel = document.createElement("label");
          nameLabel.className = "font-mono text-xs tracking-wider text-phosphor-dim mb-2 block";
          nameLabel.htmlFor = "diag-name";
          nameLabel.textContent = "> NAME";
          nameWrap.appendChild(nameLabel);
          const nameInput = document.createElement("input");
          nameInput.id = "diag-name";
          nameInput.type = "text";
          nameInput.required = true;
          nameInput.autocomplete = "name";
          nameInput.className = "input input-bordered w-full border-2 border-base-300 bg-base-200 font-mono focus:border-primary focus:outline-none";
          if (state.contactName) nameInput.value = state.contactName;
          nameWrap.appendChild(nameInput);
          const nameError = el("span", "hidden font-mono text-xs text-error mt-1 block");
          nameError.id = "diag-name-error";
          nameError.setAttribute("role", "alert");
          nameError.textContent = "[ERR] Name is required.";
          nameWrap.appendChild(nameError);
          form.appendChild(nameWrap);

          // Email field
          const emailWrap = el("div");
          const emailLabel = document.createElement("label");
          emailLabel.className = "font-mono text-xs tracking-wider text-phosphor-dim mb-2 block";
          emailLabel.htmlFor = "diag-email";
          emailLabel.textContent = "> EMAIL";
          emailWrap.appendChild(emailLabel);
          const emailInput = document.createElement("input");
          emailInput.id = "diag-email";
          emailInput.type = "email";
          emailInput.required = true;
          emailInput.autocomplete = "email";
          emailInput.className = "input input-bordered w-full border-2 border-base-300 bg-base-200 font-mono focus:border-primary focus:outline-none";
          if (state.contactEmail) emailInput.value = state.contactEmail;
          emailWrap.appendChild(emailInput);
          const emailError = el("span", "hidden font-mono text-xs text-error mt-1 block");
          emailError.id = "diag-email-error";
          emailError.setAttribute("role", "alert");
          emailError.textContent = "[ERR] Valid email required.";
          emailWrap.appendChild(emailError);
          form.appendChild(emailWrap);

          // Company field
          const companyWrap = el("div");
          const companyLabel = document.createElement("label");
          companyLabel.className = "font-mono text-xs tracking-wider text-phosphor-dim mb-2 block";
          companyLabel.htmlFor = "diag-company";
          companyLabel.textContent = "> COMPANY (optional)";
          companyWrap.appendChild(companyLabel);
          const companyInput = document.createElement("input");
          companyInput.id = "diag-company";
          companyInput.type = "text";
          companyInput.autocomplete = "organization";
          companyInput.className = "input input-bordered w-full border-2 border-base-300 bg-base-200 font-mono focus:border-primary focus:outline-none";
          if (state.contactCompany) companyInput.value = state.contactCompany;
          companyWrap.appendChild(companyInput);
          form.appendChild(companyWrap);

          // Honeypot
          const honeypot = el("div");
          honeypot.style.position = "absolute";
          honeypot.style.left = "-9999px";
          honeypot.style.opacity = "0";
          honeypot.style.height = "0";
          honeypot.style.overflow = "hidden";
          honeypot.setAttribute("aria-hidden", "true");
          const honeypotInput = document.createElement("input");
          honeypotInput.type = "text";
          honeypotInput.name = "website";
          honeypotInput.tabIndex = -1;
          honeypotInput.autocomplete = "off";
          honeypot.appendChild(honeypotInput);
          form.appendChild(honeypot);

          // Submit button
          const btnWrap = el("div", "mt-6");
          const btn = primaryButton(screen.buttonLabel || "SEE MY RESULTS");
          btn.addEventListener("click", () => {
            nameError.classList.add("hidden");
            emailError.classList.add("hidden");
            nameInput.removeAttribute("aria-invalid");
            nameInput.removeAttribute("aria-describedby");
            emailInput.removeAttribute("aria-invalid");
            emailInput.removeAttribute("aria-describedby");

            let hasError = false;
            const name = nameInput.value.trim();
            const email = emailInput.value.trim();
            const company = companyInput.value.trim();

            if (!name) {
              nameError.classList.remove("hidden");
              nameInput.setAttribute("aria-invalid", "true");
              nameInput.setAttribute("aria-describedby", "diag-name-error");
              hasError = true;
            }
            if (!email || !email.includes("@")) {
              emailError.classList.remove("hidden");
              emailInput.setAttribute("aria-invalid", "true");
              emailInput.setAttribute("aria-describedby", "diag-email-error");
              hasError = true;
            }
            if (!hasError) {
              dispatch({
                type: "EMAIL_SUBMIT",
                name,
                email,
                company: company || undefined,
              });
            }
          });
          btnWrap.appendChild(btn);
          form.appendChild(btnWrap);
          container.appendChild(form);
          return container;
        }

        function renderLoading(_screen, _state, dispatch) {
          const container = el("div", "text-center py-12");
          const label = el("p", "font-mono text-lg text-primary mb-6");
          label.textContent = "// Analyzing your answers...";
          container.appendChild(label);
          const barBg = el("div", "h-2 w-full bg-base-300");
          const barFill = el("div", "h-2 bg-primary animate-loading-fill");
          barBg.appendChild(barFill);
          container.appendChild(barBg);
          setTimeout(() => dispatch({ type: "ADVANCE", screenId: "loading" }), 1500);
          return container;
        }

        function renderResults(_screen, state) {
          const { result, aiModifier, pathScore, tier } = getFullResults(state);
          const container = el("div");

          const dimLabel = el("p", "font-mono text-xs tracking-wider text-phosphor-dim mb-4");
          dimLabel.textContent = "// DIAGNOSTIC COMPLETE";
          container.appendChild(dimLabel);

          const headline = el("h2", "text-2xl sm:text-3xl font-bold mb-6");
          headline.textContent = result.headline;
          container.appendChild(headline);

          const body = el("p", "text-base-content/80 leading-relaxed mb-8");
          body.textContent = result.body;
          container.appendChild(body);

          // Score breakdown
          const scoreSep = el("p", "font-mono text-xs text-base-content/30 mb-4");
          scoreSep.textContent = "\u2500\u2500 SCORE BREAKDOWN \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500";
          container.appendChild(scoreSep);

          const pathName = pathDisplayName(state.path);
          const scoreLabel = el("p", "font-mono text-sm mb-2");
          scoreLabel.textContent = `${pathName}: ${pathScore.score} / ${pathScore.max}`;
          container.appendChild(scoreLabel);

          const barBg = el("div", "h-2 w-full bg-base-300");
          barBg.setAttribute("role", "meter");
          barBg.setAttribute("aria-valuenow", String(pathScore.score));
          barBg.setAttribute("aria-valuemin", "0");
          barBg.setAttribute("aria-valuemax", String(pathScore.max));
          barBg.setAttribute("aria-label", `${pathName} score: ${pathScore.score} out of ${pathScore.max}`);
          const barFill = el("div", "h-2 bg-primary transition-all duration-1000");
          const pct = pathScore.max > 0 ? (pathScore.score / pathScore.max) * 100 : 0;
          barFill.style.width = pct + "%";
          barBg.appendChild(barFill);
          container.appendChild(barBg);

          const badge = tierBadge(tier);
          const tierLabel = el("p", `font-mono text-xs mt-2 ${badge.colorClass}`);
          tierLabel.textContent = `${badge.text} ${tier.toUpperCase()}`;
          container.appendChild(tierLabel);

          // Build description
          if (result.buildDescription) {
            const buildSep = el("p", "font-mono text-xs text-phosphor-dim mt-8 mb-2");
            buildSep.textContent = "// WHAT WE\u2019D BUILD";
            container.appendChild(buildSep);
            const buildBody = el("p", "text-base-content/80 leading-relaxed");
            buildBody.textContent = result.buildDescription;
            container.appendChild(buildBody);
          }

          // AI modifier
          if (aiModifier) {
            const aiSep = el("p", "font-mono text-xs text-base-content/30 mt-8 mb-4");
            aiSep.textContent = "\u2500\u2500 AI READINESS \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500";
            container.appendChild(aiSep);
            const aiBody = el("p", "text-base-content/80 leading-relaxed");
            aiBody.textContent = aiModifier;
            container.appendChild(aiBody);
          }

          // CTA
          const ctaSep = el("p", "font-mono text-xs text-base-content/30 mt-8 mb-4");
          ctaSep.textContent = "\u2500\u2500 NEXT STEP \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500";
          container.appendChild(ctaSep);
          const cta = primaryLink(result.ctaLabel, result.ctaHref);
          container.appendChild(cta);
          const ctaHint = el("p", "font-mono text-sm text-phosphor-dim mt-3");
          ctaHint.textContent = SECONDARY_CTA_TEXT;
          container.appendChild(ctaHint);

          // Secondary CTA
          const secWrap = el("div", "mt-4");
          const secLink = document.createElement("a");
          secLink.href = SECONDARY_CTA.href;
          secLink.className = "btn btn-ghost font-mono tracking-wider";
          secLink.textContent = SECONDARY_CTA.label;
          secWrap.appendChild(secLink);
          container.appendChild(secWrap);

          return container;
        }

        function renderProgressBar(progress) {
          const wrapper = el("div", "mb-8");
          const pct = Math.round(progress * 100);
          const barBg = el("div", "h-1 w-full bg-base-300");
          barBg.setAttribute("role", "progressbar");
          barBg.setAttribute("aria-valuenow", String(pct));
          barBg.setAttribute("aria-valuemin", "0");
          barBg.setAttribute("aria-valuemax", "100");
          barBg.setAttribute("aria-label", `Diagnostic progress: ${pct}%`);
          const barFill = el("div", "h-1 bg-primary transition-all duration-500");
          barFill.style.width = pct + "%";
          barBg.appendChild(barFill);
          wrapper.appendChild(barBg);
          const label = el("p", "font-mono text-xs text-phosphor-dim mt-1");
          label.textContent = `// ${pct}% complete`;
          wrapper.appendChild(label);
          return wrapper;
        }

        // ------------------------------------------------------------
        // 8. MAIN RENDER LOOP
        // ------------------------------------------------------------
        async function renderScreen(root, state, dispatch) {
          const screen = SCREENS[state.screen];
          if (!screen) return;

          const transitionMs = prefersReducedMotion() ? 0 : 150;
          root.style.opacity = "0";
          await delay(transitionMs);
          root.replaceChildren();

          currentProgress = Math.max(currentProgress, calculateProgress(state));

          // Show progress bar on question screens (not opening, results, loading, or skip screens)
          const showProgress = !new Set(["opening", "results", "loading"]).has(state.screen);
          const isSkip = isSkipScreen(state.screen);
          if (showProgress && !isSkip) {
            root.appendChild(renderProgressBar(currentProgress));
          }

          // Render screen content
          let content;
          switch (screen.type) {
            case "splash":
              content = renderSplash(screen, state, dispatch);
              break;
            case "gateway":
            case "routing":
            case "scored":
              content = renderQuestion(screen, state, dispatch);
              break;
            case "text-input":
              content = renderTextInput(screen, state, dispatch);
              break;
            case "email-gate":
              content = renderEmailGate(screen, state, dispatch);
              break;
            case "loading":
              content = renderLoading(screen, state, dispatch);
              break;
            case "results":
              content = renderResults(screen, state);
              break;
            default:
              content = el("div");
              break;
          }
          root.appendChild(content);

          // Back button (not on results or loading)
          const noBackScreens = new Set(["results", "loading"]);
          if (state.history.length > 0 && !noBackScreens.has(screen.type)) {
            const backWrap = el("div", "mt-8");
            const backBtn = document.createElement("button");
            backBtn.type = "button";
            backBtn.className = "btn btn-ghost font-mono text-xs text-base-content/40 hover:text-base-content/60";
            backBtn.textContent = "< BACK";
            backBtn.addEventListener("click", () => dispatch({ type: "BACK" }));
            backWrap.appendChild(backBtn);
            root.appendChild(backWrap);
          }

          root.style.opacity = "1";

          // Auto-advance skip screens after brief display
          if (isSkip) {
            await delay(prefersReducedMotion() ? 0 : 600);
            dispatch({ type: "ADVANCE", screenId: state.screen });
            return;
          }

          // Focus first interactive element
          const focusTarget = root.querySelector("button, input, textarea");
          if (focusTarget) focusTarget.focus({ preventScroll: true });
        }

        // ------------------------------------------------------------
        // 9. INITIALIZATION
        // ------------------------------------------------------------
        function init() {
          const root = document.getElementById("diagnostic-root");
          if (!root) return;

          let state = createState();
          function dispatch(action) {
            state = reducer(state, action);
            renderScreen(root, state, dispatch);
          }

          renderScreen(root, state, dispatch);

          // Keyboard shortcuts
          document.addEventListener("keydown", (e) => {
            if (state.screen === "results" || state.screen === "loading") return;
            const screen = SCREENS[state.screen];
            if (!screen) return;

            // Number/letter keys select options
            if (screen.options && ["1", "2", "3", "4", "a", "b", "c", "d"].includes(e.key.toLowerCase())) {
              const keyMap = { 1: 0, a: 0, 2: 1, b: 1, 3: 2, c: 2, 4: 3, d: 3 };
              const idx = keyMap[e.key.toLowerCase()] ?? -1;
              const opt = screen.options[idx];
              if (opt) dispatch({ type: "ANSWER", screenId: screen.id, value: opt.value, score: opt.score });
            }

            // Backspace goes back
            if (e.key === "Backspace" && state.history.length > 0) {
              e.preventDefault();
              dispatch({ type: "BACK" });
            }

            // S key skips scored questions
            if (
              e.key.toLowerCase() === "s" &&
              screen.type === "scored" &&
              screen.skipScore != null &&
              document.activeElement?.tagName !== "INPUT" &&
              document.activeElement?.tagName !== "TEXTAREA"
            ) {
              dispatch({ type: "SKIP", screenId: screen.id, skipScore: screen.skipScore });
            }
          });
        }

        init();
        document.addEventListener("astro:after-swap", init);
      </script>

      <script>
        // Scroll reveal (same as BaseLayout)
        function initReveal() {
          const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          document.querySelectorAll(".reveal").forEach((el) => {
            if (prefersReduced) { el.classList.add("revealed"); return; }
          });
          if (prefersReduced) return;
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) { entry.target.classList.add("revealed"); observer.unobserve(entry.target); }
            });
          }, { threshold: 0.15, rootMargin: "0px 0px -40px 0px" });
          document.querySelectorAll(".reveal:not(.revealed)").forEach((el) => observer.observe(el));
        }
        initReveal();
        document.addEventListener("astro:after-swap", initReveal);
      </script>
    </main>
  </body>
</html>

<style is:global>
  @keyframes loading-fill {
    0% { width: 0%; }
    100% { width: 100%; }
  }
  .animate-loading-fill {
    animation: loading-fill 1.5s ease-out forwards;
  }
</style>
