---
import '../styles/global.css';
import Topbar from '../components/Topbar.astro';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'MAX.EXE — We Debug the Problem',
  description = 'Maximum Execution builds websites, apps, and AI tools for small businesses. One person. Full stack. No handoffs.'
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preload" href="/fonts/GeistSans.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Topbar />
    <main>
      <slot />
    </main>
  </body>
</html>
