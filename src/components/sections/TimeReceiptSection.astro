---
import SectionWrapper from '../SectionWrapper.astro';
import Button from '../Button.astro';
---
<div class="cost-divider" aria-hidden="true"></div>
<SectionWrapper bg="dark" id="cost" class="cost-section">
  <!-- Section label -->
  <p class="section-label">// 05 THE ACTUAL COST</p>

  <!-- Section headline -->
  <h2 class="receipt-headline">
    <span>You're paying for hours your team never gets back.</span>
  </h2>
  <p class="receipt-bridge">This is what tool fragmentation costs when you put a dollar figure on it. Drag the slider to your team size.</p>

  <!-- Slider -->
  <div class="slider-area">
    <div class="slider-label-row">
      <span class="slider-label">// SELECT YOUR TEAM SIZE</span>
      <span class="slider-ticks">
        <button type="button" class="tick" data-tick="1" aria-label="Set team size to 1">1</button>
        <button type="button" class="tick" data-tick="5" aria-label="Set team size to 5">5</button>
        <button type="button" class="tick active" data-tick="10" aria-label="Set team size to 10">10</button>
        <button type="button" class="tick" data-tick="20" aria-label="Set team size to 20">20</button>
        <button type="button" class="tick" data-tick="50" aria-label="Set team size to 50">50</button>
      </span>
    </div>
    <label for="team-slider" class="sr-only">Team size selector</label>
    <input
      type="range"
      class="team-slider"
      id="team-slider"
      min="0"
      max="4"
      value="2"
      step="1"
    />
    <p class="slider-hint">// Drag to recalculate for your team</p>
  </div>

  <!-- Receipt card -->
  <div class="receipt-card">
    <!-- Receipt header -->
    <div class="receipt-header">
      <span class="receipt-logo">MAX.EXE // COST_ANALYSIS.EXE</span>
      <div class="receipt-sep" aria-hidden="true"></div>
    </div>

    <!-- Entity info -->
    <div class="receipt-meta">
      <div class="receipt-row">
        <span class="receipt-label">ENTITY</span>
        <span class="receipt-value">YOUR BUSINESS</span>
      </div>
      <div class="receipt-row">
        <span class="receipt-label">TEAM SIZE</span>
        <span class="receipt-value" data-field="team-display">10 employees [adjust above]</span>
      </div>
      <div class="receipt-row">
        <span class="receipt-label">RATE</span>
        <span class="receipt-value">$30/hr avg labor cost</span>
      </div>
      <div class="receipt-row">
        <span class="receipt-label">DATE</span>
        <span class="receipt-value">2026</span>
      </div>
    </div>

    <div class="receipt-sep" aria-hidden="true"></div>

    <!-- Line items -->
    <div class="receipt-items">
      <div class="receipt-item">
        <span class="receipt-item-name">App switching (1,200x/day)</span>
        <span class="receipt-item-detail">
          <span data-field="hours-0">208</span>hr / $<span data-field="cost-0">6,240</span>
        </span>
      </div>
      <div class="receipt-item">
        <span class="receipt-item-name">Tool fatigue + reorienting</span>
        <span class="receipt-item-detail">
          <span data-field="hours-1">440</span>hr / $<span data-field="cost-1">13,200</span>
        </span>
      </div>
      <div class="receipt-item">
        <span class="receipt-item-name">Manual data re-entry</span>
        <span class="receipt-item-detail">
          <span data-field="hours-2">96</span>hr / $<span data-field="cost-2">2,880</span>
        </span>
      </div>
      <div class="receipt-item">
        <span class="receipt-item-name">Unresolved integrations</span>
        <span class="receipt-item-detail">
          <span data-field="hours-3">120</span>hr / $<span data-field="cost-3">3,600</span>
        </span>
      </div>
      <div class="receipt-item">
        <span class="receipt-item-name">File and data hunting</span>
        <span class="receipt-item-detail">
          <span data-field="hours-4">60</span>hr / $<span data-field="cost-4">1,800</span>
        </span>
      </div>
    </div>

    <div class="receipt-sep-double" aria-hidden="true"></div>

    <!-- Totals -->
    <div class="receipt-totals">
      <div class="receipt-total-row">
        <span class="receipt-total-label">TOTAL HOURS</span>
        <span class="receipt-total-value" data-field="total-hours">924 hrs/yr</span>
      </div>
      <div class="receipt-total-row receipt-grand-total">
        <span class="receipt-total-label">TOTAL COST</span>
        <span class="receipt-total-value receipt-grand-value" data-field="total-cost">$27,720/yr</span>
      </div>
    </div>

    <div class="receipt-sep" aria-hidden="true"></div>

    <!-- Status lines -->
    <div class="receipt-status">
      <p class="status-err"><span class="err-badge">[ERR]</span> ROOT CAUSE: FRAGMENTED STACK</p>
      <p class="status-err"><span class="err-badge">[ERR]</span> NO SINGLE SOURCE OF TRUTH DETECTED</p>
      <p class="status-fix">FIX: DIAGNOSTIC &rarr; INTEGRATION &rarr; DEPLOY</p>
    </div>

    <div class="receipt-sep" aria-hidden="true"></div>

    <!-- Sources -->
    <p class="receipt-sources">Sources: HBR/Harvard Business School &middot; Lokalise/Fast Company 2025</p>
  </div>

  <!-- CTA -->
  <div class="cost-cta">
    <Button variant="primary" href="#diagnostic">WHAT'S YOUR NUMBER? RUN THE FREE DIAGNOSTIC &gt;</Button>
  </div>

  <!-- Section bottom rule -->
  <div class="section-bottom-rule" aria-hidden="true"></div>
</SectionWrapper>

<style>
  /* Amber divider rule at top */
  .cost-divider {
    height: 1px;
    background: oklch(0.76 0.18 62 / 0.15);
  }

  /* Section label */
  .section-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-accent-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  /* Section headline */
  .receipt-headline {
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    line-height: 1.4;
    color: oklch(0.88 0.06 62);
    max-width: 560px;
    margin-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .receipt-bridge {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.65;
    color: oklch(0.88 0.06 62);
    max-width: 560px;
    margin-bottom: var(--space-8);
  }

  /* ── Receipt Card ── */
  .receipt-card {
    max-width: 560px;
    margin: 0 auto;
    background: oklch(0.12 0.02 85);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    font-family: var(--font-mono);
    font-feature-settings: 'tnum' 1;
    transition: border-color 300ms var(--ease-ui);
  }

  .receipt-card.value-changed {
    border-color: oklch(0.76 0.18 62 / 0.6);
  }

  /* Receipt header */
  .receipt-header {
    margin-bottom: var(--space-4);
  }

  .receipt-logo {
    font-size: var(--step--1);
    font-weight: 700;
    color: oklch(0.76 0.18 62 / 0.8);
    letter-spacing: 0.06em;
    display: block;
    margin-bottom: var(--space-3);
  }

  /* Separator */
  .receipt-sep {
    height: 1px;
    background: oklch(0.76 0.18 62 / 0.2);
    margin: var(--space-4) 0;
  }

  .receipt-sep-double {
    height: 1px;
    border-top: 1px solid oklch(0.76 0.18 62 / 0.2);
    border-bottom: 1px solid oklch(0.76 0.18 62 / 0.2);
    height: 4px;
    margin: var(--space-5) 0;
  }

  /* Meta rows */
  .receipt-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .receipt-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 13px;
    line-height: 1.5;
  }

  .receipt-label {
    color: var(--text-accent-dim);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .receipt-value {
    color: oklch(0.76 0.18 62 / 1);
    text-align: right;
  }

  /* Line items */
  .receipt-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .receipt-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 13px;
    line-height: 1.5;
    gap: var(--space-4);
  }

  .receipt-item-name {
    color: var(--text-accent-dim);
    flex-shrink: 0;
  }

  .receipt-item-detail {
    color: oklch(0.76 0.18 62 / 1);
    text-align: right;
    white-space: nowrap;
  }

  /* Totals */
  .receipt-totals {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .receipt-total-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 14px;
  }

  .receipt-total-label {
    color: var(--text-accent-dim);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .receipt-total-value {
    color: oklch(0.76 0.18 62 / 1);
    font-weight: 600;
  }

  .receipt-grand-total {
    margin-top: var(--space-1);
  }

  .receipt-grand-value {
    font-size: 20px;
    font-weight: 700;
    color: var(--primary);
  }

  /* Status lines */
  .receipt-status {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: 13px;
    line-height: 1.5;
  }

  .status-err {
    color: var(--danger);
  }

  .err-badge {
    font-weight: 700;
    padding: 1px 4px;
    border: 1px solid var(--danger);
    margin-right: 4px;
    font-size: 11px;
  }

  .status-fix {
    color: var(--success);
    font-weight: 500;
  }

  /* Sources */
  .receipt-sources {
    font-size: 11px;
    color: var(--text-accent-dim);
    line-height: 1.5;
  }

  /* ── Slider Area ── */
  .slider-area {
    max-width: 560px;
    margin: 0 auto;
    margin-bottom: var(--space-8);
  }

  .slider-label-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
    font-family: var(--font-mono);
    font-size: 14px;
  }

  .slider-label {
    color: var(--text-accent-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .slider-ticks {
    display: flex;
    justify-content: space-between;
    flex: 1;
  }

  .tick {
    background: none;
    border: none;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--text-accent-dim);
    font-feature-settings: 'tnum' 1;
    cursor: pointer;
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    transition: color var(--dur-micro) var(--ease-ui);
  }

  .tick.active {
    color: var(--primary);
    font-weight: 700;
  }

  .tick:hover {
    color: oklch(0.76 0.18 62 / 0.7);
  }

  .tick:focus-visible {
    outline: 2px solid oklch(0.76 0.18 62);
    outline-offset: 2px;
  }

  /* Range slider custom styling */
  .team-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 8px;
    background: oklch(0.76 0.18 62 / 0.2);
    border-radius: 4px;
    cursor: pointer;
  }

  .team-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--primary);
    border: 2px solid oklch(0.12 0.02 85);
    box-shadow: 0 0 8px oklch(0.76 0.18 62 / 0.4);
    cursor: pointer;
    transition: box-shadow var(--dur-micro) var(--ease-ui),
                transform var(--dur-micro) var(--ease-ui);
  }

  .team-slider::-webkit-slider-thumb:hover {
    box-shadow: 0 0 16px oklch(0.76 0.18 62 / 0.6);
    transform: scale(1.15);
  }

  .team-slider::-moz-range-thumb {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--primary);
    border: 2px solid oklch(0.12 0.02 85);
    box-shadow: 0 0 8px oklch(0.76 0.18 62 / 0.4);
    cursor: pointer;
  }

  .team-slider::-moz-range-track {
    height: 8px;
    background: oklch(0.76 0.18 62 / 0.2);
    border-radius: 4px;
  }

  .team-slider:focus-visible {
    outline: 2px solid oklch(0.76 0.18 62);
    outline-offset: 4px;
  }

  .slider-hint {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-accent-dim);
    margin-top: var(--space-2);
    letter-spacing: 0.04em;
  }

  /* ── CTA ── */
  .cost-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-12);
  }

  /* ── Section bottom rule ── */
  .section-bottom-rule {
    height: 1px;
    background: oklch(0.76 0.18 62 / 0.20);
    margin-top: var(--space-20);
    max-width: 100%;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .receipt-card {
      padding: var(--space-5);
    }

    .receipt-item {
      flex-direction: column;
      gap: 2px;
    }

    .receipt-item-detail {
      text-align: left;
      padding-left: var(--space-4);
    }

    .receipt-grand-value {
      font-size: 18px;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .team-slider::-webkit-slider-thumb {
      transition: none;
    }

    .receipt-card {
      transition: none;
    }
  }
</style>

<script>
  const TEAM_SIZES = [1, 5, 10, 20, 50];
  const RATE = 30;
  const PER_EMPLOYEE_HOURS = [20.8, 44, 9.6, 12, 6];

  const slider = document.getElementById('team-slider') as HTMLInputElement;
  const ticks = document.querySelectorAll('.tick');
  const receiptCard = document.querySelector('.receipt-card');

  function formatNumber(n: number): string {
    return Math.round(n).toLocaleString('en-US');
  }

  function update(teamSize: number): void {
    // Update team display
    const teamDisplay = document.querySelector('[data-field="team-display"]');
    if (teamDisplay) {
      teamDisplay.textContent = `${teamSize} employee${teamSize === 1 ? '' : 's'} [adjust above]`;
    }

    // Update line items
    let totalHours = 0;
    PER_EMPLOYEE_HOURS.forEach((baseHours, i) => {
      const hours = Math.round(baseHours * teamSize);
      const cost = hours * RATE;
      totalHours += hours;

      const hoursEl = document.querySelector(`[data-field="hours-${i}"]`);
      const costEl = document.querySelector(`[data-field="cost-${i}"]`);
      if (hoursEl) hoursEl.textContent = formatNumber(hours);
      if (costEl) costEl.textContent = formatNumber(cost);
    });

    // Update totals
    const totalCost = totalHours * RATE;
    const totalHoursEl = document.querySelector('[data-field="total-hours"]');
    const totalCostEl = document.querySelector('[data-field="total-cost"]');
    if (totalHoursEl) totalHoursEl.textContent = `${formatNumber(totalHours)} hrs/yr`;
    if (totalCostEl) totalCostEl.textContent = `$${formatNumber(totalCost)}/yr`;

    // Update active tick
    ticks.forEach((tick) => {
      const tickVal = Number(tick.getAttribute('data-tick'));
      tick.classList.toggle('active', tickVal === teamSize);
    });
  }

  function flashReceipt(): void {
    if (receiptCard) {
      receiptCard.classList.add('value-changed');
      setTimeout(() => receiptCard.classList.remove('value-changed'), 300);
    }
  }

  // Slider input handler
  slider?.addEventListener('input', () => {
    const teamSize = TEAM_SIZES[Number(slider.value)];
    update(teamSize);
    flashReceipt();
  });

  // Tick click handler
  ticks.forEach((tick) => {
    tick.addEventListener('click', () => {
      const tickVal = Number(tick.getAttribute('data-tick'));
      const index = TEAM_SIZES.indexOf(tickVal);
      if (index !== -1 && slider) {
        slider.value = String(index);
        update(tickVal);
        flashReceipt();
      }
    });
  });
</script>
