---
import SectionWrapper from '../SectionWrapper.astro';
import Button from '../Button.astro';
---
<SectionWrapper id="diagnostic" theme="light">
  <!-- Section label -->
  <p class="section-label section-label--light">// 07 FREE DIAGNOSTIC</p>

  <!-- Headline -->
  <h2 class="diagnostic-headline">Five minutes. Find out exactly what's broken.</h2>

  <!-- Body -->
  <div class="diagnostic-body" data-animate>
    <p>
      The diagnostic isn't a contact form. It's a set of questions that adjusts
      based on your situation. At the end, I send a plain-language written report
      to your inbox: which layer of your operating system is broken, and what
      type of project fits your situation.
    </p>

    <p>
      It's free. You get the written report before we talk. No sales call
      required to see the results.
    </p>
  </div>

  <!-- Preview rows -->
  <ol class="preview-rows" data-animate>
    <li class="preview-row">
      <span class="preview-num" aria-hidden="true">&gt; [01]</span>
      <h3 class="preview-title">TELL ME ABOUT YOUR BUSINESS</h3>
    </li>

    <li class="preview-row">
      <span class="preview-num" aria-hidden="true">&gt; [02]</span>
      <h3 class="preview-title">ANSWER WHAT APPLIES TO YOUR SITUATION</h3>
    </li>

    <li class="preview-row">
      <span class="preview-num" aria-hidden="true">&gt; [03]</span>
      <h3 class="preview-title">GET YOUR WRITTEN DIAGNOSTIC REPORT</h3>
    </li>
  </ol>

  <!-- CTA -->
  <div class="diagnostic-cta">
    <Button variant="primary" href="/diagnostic">[START FREE DIAGNOSTIC &gt;]</Button>
    <div class="cta-reassurance">
      <p>// Five minutes. Free.</p>
      <p>// Your written report arrives in your inbox.</p>
      <p>// No email required to start.</p>
    </div>
  </div>
</SectionWrapper>

<style>
  /* Headline - Geist Sans */
  .diagnostic-headline {
    font-family: var(--font-sans);
    font-size: var(--step-4);
    line-height: 1.15;
    letter-spacing: var(--tracking-snug);
    color: var(--text);
    margin-bottom: var(--space-8);
    max-width: var(--measure-wide);
  }

  /* Body */
  .diagnostic-body {
    max-width: var(--measure-normal);
    margin-bottom: var(--space-10);
  }

  .diagnostic-body p {
    font-family: var(--font-sans);
    font-size: var(--step-0);
    line-height: 1.65;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
  }

  .diagnostic-body p:last-child {
    margin-bottom: 0;
  }

  /* Preview rows - terminal style */
  .preview-rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-muted);
    list-style: none;
    padding-left: 0;
  }

  .preview-row {
    display: flex;
    gap: var(--space-4);
    align-items: baseline;
  }

  .preview-num {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-feature-settings: 'tnum' 1;
    color: var(--primary);
    flex-shrink: 0;
  }

  .preview-title {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--text);
    line-height: 1.5;
    letter-spacing: 0.02em;
  }

  /* CTA */
  .diagnostic-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .cta-reassurance p {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-muted);
    letter-spacing: 0.04em;
    line-height: 1.5;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .diagnostic-headline {
      font-size: var(--step-3);
    }
  }

  @media (max-width: 480px) {
    .diagnostic-headline {
      font-size: var(--step-2);
    }
  }
</style>
