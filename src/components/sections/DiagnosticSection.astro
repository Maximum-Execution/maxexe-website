---
import SectionWrapper from '../SectionWrapper.astro';
import Button from '../Button.astro';
---
<div class="diagnostic-divider" aria-hidden="true"></div>
<SectionWrapper bg="light" id="diagnostic" class="diagnostic-section">
  <div class="diagnostic-inner">
    <!-- Section label -->
    <p class="section-label">// 07 THE MAX.EXE DIAGNOSTIC</p>

    <!-- Headline -->
    <h2 class="diagnostic-headline">
      <span>84% of technology projects fail.</span>
      <span>Yours doesn&rsquo;t have to.</span>
    </h2>

    <!-- Subhead -->
    <p class="diagnostic-subhead">
      Find out what's actually broken. Before you spend a dollar trying to fix it.
    </p>

    <!-- Body -->
    <div class="diagnostic-body">
      <p>
        The MAX.EXE Business Diagnostic is a branching decision tree. You only
        answer questions that apply to your situation. Tell it you need a website and it
        asks about your website. Tell it you need software and it digs into your workflow.
        Add AI and it explores where AI actually fits your business.
      </p>
      <p>
        Takes about five minutes. You see your full results before we ask for
        anything. Because a diagnosis you haven't read yet isn't worth your email.
      </p>
      <p>
        At the end: an AI-generated analysis of your specific answers, a gap assessment
        tied to the outcome you described, and a clear recommendation for what to build
        first. Not a score bucket. Not a generic PDF. A diagnosis that reads like it was
        written for your business. Because it was.
      </p>
    </div>

    <!-- Preview rows -->
    <div class="preview-rows">
      <div class="preview-row">
        <div class="preview-num">&gt; [01]</div>
        <div class="preview-content">
          <p class="preview-title">TELL US WHAT YOU NEED</p>
          <p class="preview-desc">
            Website, software, or both. The diagnostic only asks
            questions that apply to your situation.
          </p>
        </div>
      </div>

      <div class="preview-row">
        <div class="preview-num">&gt; [02]</div>
        <div class="preview-content">
          <p class="preview-title">ANSWER WHAT APPLIES</p>
          <p class="preview-desc">
            No generic quiz. Questions adapt to your path.
            Takes about five minutes.
          </p>
        </div>
      </div>

      <div class="preview-row">
        <div class="preview-num">&gt; [03]</div>
        <div class="preview-content">
          <p class="preview-title">GET YOUR DIAGNOSIS</p>
          <p class="preview-desc">
            See your AI-generated gap analysis immediately after
            completing the diagnostic. No email required to see
            your results.
          </p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="diagnostic-cta">
      <p class="cta-heading">Ready to execute?</p>
      <Button variant="primary" href="/diagnostic">[START DIAGNOSTIC &gt;]</Button>
      <p class="cta-reassurance">// Free. Five minutes. No email required to see your results.</p>
    </div>
  </div>

  <!-- Section bottom rule -->
  <div class="section-bottom-rule" aria-hidden="true"></div>
</SectionWrapper>

<style>
  /* Amber divider rule at top */
  .diagnostic-divider {
    height: 1px;
    background: oklch(0.76 0.18 62 / 0.15);
  }

  /* Inner container - 860px max */
  .diagnostic-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  /* Section label - monospace, small, amber at 35% */
  .section-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-accent-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  /* Headline - Geist Pixel, two lines */
  .diagnostic-headline {
    font-family: var(--font-pixel);
    font-size: var(--step-4);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: var(--space-8);
  }

  .diagnostic-headline span {
    display: block;
  }

  .diagnostic-headline span:first-child {
    color: var(--primary);
  }

  .diagnostic-headline span:last-child {
    color: var(--text-accent-muted);
  }

  /* Subhead - Geist Mono, amber 60% */
  .diagnostic-subhead {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--text-accent-dim);
    line-height: 1.6;
    margin-bottom: var(--space-10);
  }

  /* Body - Geist Sans, 17px, warm off-white */
  .diagnostic-body {
    margin-bottom: var(--space-12);
  }

  .diagnostic-body p {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.65;
    color: oklch(0.88 0.06 62);
    margin-bottom: var(--space-6);
  }

  .diagnostic-body p:last-child {
    margin-bottom: 0;
  }

  /* ── Preview rows ── */
  .preview-rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-muted);
  }

  .preview-row {
    display: flex;
    gap: var(--space-5);
    align-items: flex-start;
  }

  .preview-num {
    font-family: var(--font-mono);
    font-size: 14px;
    font-feature-settings: 'tnum' 1;
    color: var(--primary);
    flex-shrink: 0;
    line-height: 1.5;
    padding-top: 1px;
  }

  .preview-content {
    flex: 1;
  }

  .preview-title {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.4;
    margin-bottom: var(--space-1);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .preview-desc {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.6;
    color: oklch(0.88 0.06 62 / 0.8);
  }

  /* ── CTA ── */
  .diagnostic-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .cta-heading {
    font-family: var(--font-pixel);
    font-size: var(--step-1);
    color: var(--text);
    margin-bottom: var(--space-4);
  }

  .cta-reassurance {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-accent-dim);
    letter-spacing: 0.04em;
    line-height: 1.5;
  }

  /* ── Section bottom rule ── */
  .section-bottom-rule {
    height: 1px;
    background: oklch(0.76 0.18 62 / 0.20);
    margin-top: var(--space-20);
    max-width: 100%;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .diagnostic-headline {
      font-size: var(--step-3);
    }

  }

  @media (max-width: 480px) {
    .diagnostic-headline {
      font-size: var(--step-2);
    }

    .preview-row {
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
