---
import SectionWrapper from '../SectionWrapper.astro';
import Button from '../Button.astro';
---
<div class="diagnostic-divider" aria-hidden="true"></div>
<SectionWrapper bg="light" id="diagnostic" class="diagnostic-section">
  <div class="diagnostic-frame">
    <div class="diagnostic-inner">
      <!-- Section label -->
      <p class="section-label">// 08 THE FREE DIAGNOSTIC</p>

      <!-- Headline -->
      <h2 class="diagnostic-headline">
        <span>Find out what's broken.</span>
        <span>It takes five minutes and costs nothing.</span>
      </h2>

      <!-- Body -->
      <div class="diagnostic-body">
        <p>
          The diagnostic isn't a contact form. It's a branching set of questions
          that adjusts to your situation. At the end, you get a plain-language
          readout of what's likely broken and what type of project fits your
          situation. You see the results before we ask for your email.
        </p>
      </div>

      <!-- Preview rows -->
      <div class="preview-rows">
        <div class="preview-row">
          <div class="preview-num">&gt; [01]</div>
          <div class="preview-content">
            <h3 class="preview-title">TELL US WHAT YOU NEED</h3>
          </div>
        </div>

        <div class="preview-row">
          <div class="preview-num">&gt; [02]</div>
          <div class="preview-content">
            <h3 class="preview-title">ANSWER WHAT APPLIES TO YOUR SITUATION</h3>
          </div>
        </div>

        <div class="preview-row">
          <div class="preview-num">&gt; [03]</div>
          <div class="preview-content">
            <h3 class="preview-title">GET YOUR DIAGNOSIS. NO EMAIL REQUIRED TO SEE RESULTS.</h3>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="diagnostic-cta">
        <Button variant="primary" href="/diagnostic">[START FREE DIAGNOSTIC &gt;]</Button>
        <p class="cta-reassurance">// Five minutes. Free. Results before we ask for anything.</p>
      </div>
    </div>
  </div>
</SectionWrapper>

<style>
  /* Amber divider rule at top */
  .diagnostic-divider {
    height: 1px;
    background: var(--border);
  }

  /* Amber border frame around the section content */
  .diagnostic-frame {
    border: 1px solid var(--border);
    padding: var(--space-12) var(--space-10);
  }

  /* Inner container - 860px max */
  .diagnostic-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  /* Section label */
  .section-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-accent-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  /* Headline */
  .diagnostic-headline {
    font-family: var(--font-pixel);
    font-size: var(--step-4);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: var(--space-8);
  }

  .diagnostic-headline span {
    display: block;
  }

  .diagnostic-headline span:first-child {
    color: var(--primary);
  }

  .diagnostic-headline span:last-child {
    color: oklch(0.76 0.18 62 / 0.7);
  }

  /* Body */
  .diagnostic-body {
    margin-bottom: var(--space-12);
  }

  .diagnostic-body p {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.65;
    color: oklch(0.88 0.06 62);
  }

  /* Preview rows - terminal style */
  .preview-rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-muted);
  }

  .preview-row {
    display: flex;
    gap: var(--space-4);
    align-items: baseline;
  }

  .preview-num {
    font-family: var(--font-mono);
    font-size: 14px;
    font-feature-settings: 'tnum' 1;
    color: var(--amber-2);
    flex-shrink: 0;
  }

  .preview-title {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.5;
    letter-spacing: 0.02em;
  }

  /* CTA */
  .diagnostic-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  /* CTA button override - brightest element */
  .diagnostic-cta :global(.btn-primary) {
    background: var(--amber-4);
    color: var(--bg-dark);
    border-color: var(--amber-4);
    font-weight: 700;
  }

  .diagnostic-cta :global(.btn-primary:hover) {
    background: oklch(0.92 0.14 86);
    border-color: oklch(0.92 0.14 86);
  }

  .cta-reassurance {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-accent-dim);
    letter-spacing: 0.04em;
    line-height: 1.5;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .diagnostic-frame {
      padding: var(--space-8) var(--space-6);
    }

    .diagnostic-headline {
      font-size: var(--step-3);
    }
  }

  @media (max-width: 480px) {
    .diagnostic-frame {
      padding: var(--space-6) var(--space-4);
    }

    .diagnostic-headline {
      font-size: var(--step-2);
    }
  }
</style>
