---
import SectionWrapper from '../SectionWrapper.astro';
import Button from '../Button.astro';
---
<div class="success-divider" aria-hidden="true"></div>
<section class="success-section" id="success">
  <!-- Section label -->
  <p class="section-label section-label--light">// 06 SUCCESS VISION</p>

  <!-- Content wrapper - 640px centered -->
  <div class="success-content">
    <!-- Headline -->
    <h2 class="success-headline">
      <span>You stop chasing clients.</span>
      <span>They start finding you.</span>
    </h2>

    <!-- Body paragraph -->
    <div class="success-body">
      <p>
        Clients land on your site and understand exactly what you do. They reach
        out without friction. Leads come in from people who found you, not just
        people who already knew you. Your tools connect to each other. Your
        workflow runs without you holding the pieces together. You spend your time
        doing the work, not explaining it.
      </p>
    </div>

    <!-- Confirmation stack -->
    <ul class="confirmation-stack">
      <li class="confirm-line">
        <span class="confirm-badge" aria-hidden="true">[OK]</span>
        <span class="confirm-text">Clients find you, understand you, and reach out. Without friction.</span>
      </li>
      <li class="confirm-line">
        <span class="confirm-badge" aria-hidden="true">[OK]</span>
        <span class="confirm-text">Tools connect to each other. Not a pile of apps. A system.</span>
      </li>
      <li class="confirm-line">
        <span class="confirm-badge" aria-hidden="true">[OK]</span>
        <span class="confirm-text">AI handles intake, FAQs, and follow-ups in your voice, on your data.</span>
      </li>
      <li class="confirm-line">
        <span class="confirm-badge" aria-hidden="true">[OK]</span>
        <span class="confirm-text">You own every line of code. No subscriptions. No lock-in. No fees owed to us.</span>
      </li>
      <li class="confirm-line">
        <span class="confirm-badge" aria-hidden="true">[OK]</span>
        <span class="confirm-text">One person knows your full system and responds in under 24 hours.</span>
      </li>
      <li class="confirm-line">
        <span class="confirm-badge" aria-hidden="true">[OK]</span>
        <span class="confirm-text">Your site, tools, and automations sound and feel like the same business.</span>
      </li>
    </ul>

    <!-- CTA -->
    <div class="success-cta">
      <Button variant="primary" href="#diagnostic">[START YOUR PROJECT &gt;]</Button>
    </div>
  </div>
</section>

<style>
  /* Amber divider rule at top — uses light-mode border */
  .success-divider {
    height: 1px;
    background: var(--light-border);
  }

  /* ── Full Light Mode Inversion ── */
  .success-section {
    background: var(--light-bg);
    color: var(--light-text);
    padding: var(--space-24) var(--space-8);
  }

  /* Content wrapper - centered 640px */
  .success-content {
    max-width: var(--measure-normal);
    margin: 0 auto;
  }

  /* Headline - darkest amber for light mode */
  .success-headline {
    font-family: var(--font-sans);
    font-size: var(--step-4);
    line-height: 1.15;
    letter-spacing: var(--tracking-snug);
    color: var(--light-h2);
    margin-bottom: var(--space-10);
  }

  .success-headline span {
    display: block;
  }

  .success-headline span:last-child {
    color: oklch(0.35 0.12 62);
  }

  /* Body copy */
  .success-body {
    margin-bottom: var(--space-12);
  }

  .success-body p {
    font-family: var(--font-sans);
    font-size: var(--step-0);
    line-height: 1.65;
    color: oklch(0.35 0.10 62);
  }

  /* ── Confirmation stack ── */
  .confirmation-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }

  .confirm-line {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    line-height: 1.5;
    background: var(--light-badge-bg);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--light-border);
  }

  .confirm-badge {
    flex-shrink: 0;
    font-weight: 600;
    color: oklch(0.40 0.16 160);
  }

  .confirm-text {
    color: var(--light-text);
  }

  /* ── CTA ── */
  .success-cta {
    display: flex;
  }

  /* Override button colors for light mode */
  .success-cta :global(.btn-primary) {
    background: var(--light-h2);
    color: var(--light-bg);
    border-color: var(--light-h2);
  }

  .success-cta :global(.btn-primary:hover) {
    background: oklch(0.30 0.14 62);
    border-color: oklch(0.30 0.14 62);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .success-section {
      padding: var(--space-16) var(--space-6);
    }

    .success-headline {
      font-size: var(--step-3);
    }

    .confirm-line {
      font-size: var(--step--1);
    }
  }

  @media (max-width: 480px) {
    .success-headline {
      font-size: var(--step-2);
    }

    .confirm-line {
      font-size: var(--step--2);
      gap: var(--space-2);
    }
  }
</style>
