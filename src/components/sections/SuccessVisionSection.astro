---
import SectionWrapper from '../SectionWrapper.astro';
import Button from '../Button.astro';
---
<SectionWrapper id="success" theme="amber">
  <!-- Section label -->
  <p class="section-label section-label--light">// 06 THE RESULT</p>

  <!-- Headline -->
  <h2 class="success-headline">What your business looks like when the system works.</h2>

  <!-- Prose scene — skeuomorphic card -->
  <div class="success-card" data-animate>
    <div class="success-body">
      <p>
        Clients land on your site and immediately understand what you do. They
        reach out. You're not explaining the business to every new person who
        finds it. The site handles that.
      </p>

      <p>
        Your tools connect to each other. There's no copy-paste loop between apps
        that weren't designed to talk. Your intake runs automatically. Your
        follow-up goes out in your voice, on your schedule.
      </p>

      <p>
        You own every line of code. No platform holds it hostage. No monthly bill
        owed to me. No calling me to make a simple update.
      </p>

      <p class="success-emphasis">
        You spend your time doing the work. Not managing the system that's
        supposed to support it. Your business finally looks as good as it
        actually is.
      </p>
    </div>
  </div>

  <!-- Scarcity note -->
  <p class="success-scarcity">
    // Currently accepting 2 of 3 project slots. When a slot opens, the diagnostic is how you get in line.
  </p>

  <!-- CTA -->
  <div class="success-cta">
    <Button variant="primary" href="#diagnostic">[START YOUR PROJECT &gt;]</Button>
  </div>
</SectionWrapper>

<style>
  /* Headline - Geist Sans */
  .success-headline {
    font-family: var(--font-sans);
    font-size: var(--step-4);
    line-height: 1.15;
    letter-spacing: var(--tracking-snug);
    color: var(--text);
    margin-bottom: var(--space-10);
    max-width: var(--measure-wide);
  }

  /* Skeuomorphic prose card */
  .success-card {
    background: oklch(0.83 0.14 62);
    box-shadow: 0 4px 16px oklch(0 0 0 / 0.2), inset 0 1px 0 oklch(1 0 0 / 0.08);
    border-radius: var(--radius-panel);
    padding: var(--space-10);
    margin-bottom: var(--space-10);
  }

  /* Body prose */
  .success-body {
    max-width: var(--measure-normal);
  }

  .success-body p {
    font-family: var(--font-sans);
    font-size: var(--step-0);
    line-height: 1.65;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
  }

  .success-body p:last-child {
    margin-bottom: 0;
  }

  /* Emphasis on closing paragraph */
  .success-emphasis {
    font-weight: 600;
    color: var(--text) !important;
    font-size: var(--step-1) !important;
  }

  /* Scarcity note */
  .success-scarcity {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-muted);
    letter-spacing: 0.06em;
    max-width: var(--measure-normal);
    margin-bottom: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-muted);
  }

  /* CTA area */
  .success-cta {
    display: flex;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .success-headline {
      font-size: var(--step-3);
    }
  }

  @media (max-width: 480px) {
    .success-headline {
      font-size: var(--step-2);
    }
  }
</style>
