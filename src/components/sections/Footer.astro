---
import Button from '../Button.astro';
import Cursor from '../Cursor.astro';
---
<div class="footer-rule" aria-hidden="true"></div>
<footer class="site-footer">
  <div class="footer-inner">
    <!-- Top area: brand + CTAs -->
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <p class="brand-name">MAXIMUM EXECUTION<Cursor class="footer-cursor" /></p>
        <p class="brand-tagline">// Clarity. Code. Results.</p>
      </div>

      <!-- CTAs -->
      <div class="footer-ctas">
        <Button variant="primary" href="#diagnostic" class="footer-btn">[START YOUR PROJECT &gt;]</Button>
        <Button variant="ghost" href="/diagnostic" class="footer-btn">[RUN THE FREE DIAGNOSTIC &gt;]</Button>
      </div>
    </div>

    <!-- Middle: contact + nav -->
    <div class="footer-mid">
      <!-- Contact -->
      <div class="footer-contact">
        <p class="contact-line">Richmond, VA</p>
        <a href="mailto:contact@maximumexecution.com" class="contact-link">contact@maximumexecution.com</a>
      </div>

      <!-- Nav links -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="#services" class="nav-link">Services</a>
        <a href="#process" class="nav-link">Process</a>
        <a href="#about" class="nav-link">About</a>
        <a href="#faq" class="nav-link">FAQ</a>
        <a href="/privacy" class="nav-link">Privacy Policy</a>
      </nav>
    </div>

    <!-- Bottom sign-off -->
    <div class="footer-signoff">
      <p class="copyright">&copy; 2026 Maximum Execution</p>
      <p class="signoff-comment">// Compiled. Deployed. Executing.</p>
      <p class="signoff-eof">EOF</p>
    </div>
  </div>
</footer>

<style>
  /* 1px amber rule separating from previous section */
  .footer-rule {
    height: 1px;
    background: var(--border);
  }

  /* Footer background - darkest value in system */
  .site-footer {
    background: var(--crt-black);
    padding: var(--space-16) var(--space-8);
    overflow: hidden;
  }

  /* Inner container */
  .footer-inner {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  /* Top area: brand + CTAs */
  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-10);
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid oklch(0.76 0.18 62 / 0.1);
  }

  /* Brand */
  .brand-name {
    font-family: var(--font-pixel);
    font-size: var(--step-0);
    color: var(--primary);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-2);
  }

  :global(.footer-cursor) {
    width: 0.45em;
    height: 0.85em;
    margin-left: 2px;
  }

  .brand-tagline {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--text-accent-dim);
    letter-spacing: 0.04em;
  }

  /* CTAs */
  .footer-ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer-ctas :global(.footer-btn) {
    font-size: var(--step--2);
    padding: var(--space-2) var(--space-5);
  }

  /* Middle: contact + nav */
  .footer-mid {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-10);
    margin-bottom: var(--space-12);
  }

  /* Contact */
  .footer-contact {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    line-height: 1.6;
  }

  .contact-line {
    color: var(--amber-2);
    margin-bottom: var(--space-1);
  }

  .contact-link {
    display: block;
    color: var(--amber-2);
    text-decoration: none;
    transition: color var(--dur-micro) var(--ease-ui);
  }

  .contact-link:hover {
    color: var(--primary);
  }

  /* Nav links */
  .footer-nav {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--amber-2);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color var(--dur-micro) var(--ease-ui);
  }

  .nav-link:hover {
    color: var(--primary);
  }

  /* Bottom sign-off */
  .footer-signoff {
    border-top: 1px solid oklch(0.76 0.18 62 / 0.1);
    padding-top: var(--space-6);
    text-align: center;
  }

  .copyright {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--amber-2);
    margin-bottom: var(--space-4);
  }

  .signoff-comment {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--amber-2);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-4);
  }

  .signoff-eof {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--amber-2);
    letter-spacing: 0.2em;
  }

  /* Responsive - single column on mobile */
  @media (max-width: 768px) {
    .site-footer {
      padding: var(--space-12) var(--space-6);
    }

    .footer-top {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-6);
    }

    .footer-mid {
      flex-direction: column;
      gap: var(--space-6);
    }

    .footer-nav {
      flex-direction: column;
      gap: var(--space-3);
    }

    .brand-name {
      font-size: var(--step--1);
    }
  }
</style>
