---
import SectionWrapper from '../SectionWrapper.astro';
import Button from '../Button.astro';
---
<div class="process-divider" aria-hidden="true"></div>
<SectionWrapper bg="base" id="process" class="process-section">
  <!-- Section label -->
  <p class="section-label">// 05 THE PLAN</p>

  <!-- Intro headline -->
  <h2 class="process-headline">
    <span>Three steps.</span>
    <span>Zero guessing.</span>
  </h2>

  <!-- Pipeline -->
  <div class="pipeline-wrapper" data-animate>
    <!-- Pipeline connecting line (desktop: horizontal, mobile: vertical) -->
    <div class="pipeline-line" aria-hidden="true"></div>
    <ol class="pipeline">
    <!-- Step 01: CLARITY -->
    <li class="step">
      <div class="step-node-area" aria-hidden="true">
        <span class="step-num-label">Step 01</span>
        <div class="step-node">01</div>
      </div>
      <div class="step-content">
        <h3 class="step-title">CLARITY</h3>
        <p class="step-body">
          The diagnostic is free. We map what's broken. Then we write the Problem
          Statement in plain language. No jargon. No assumptions. You read it. If
          it's not right, we fix it. No code gets written until you sign off.
        </p>
        <div class="step-outcome-block">
          <p class="step-outcome">&gt; OUTCOME: The Problem Statement. A written diagnosis you read and verify before anything is built.</p>
          <p class="step-comment">// Diagnostic is free. Takes five minutes.</p>
        </div>
      </div>
    </li>

    <!-- Step 02: CODE -->
    <li class="step">
      <div class="step-node-area" aria-hidden="true">
        <span class="step-num-label">Step 02</span>
        <div class="step-node">02</div>
      </div>
      <div class="step-content">
        <h3 class="step-title">CODE</h3>
        <p class="step-body">
          One person builds your project from start to finish. No templates. No
          agency layers. No handoffs to someone who wasn't in the room when the
          problem was defined. Ships with full documentation so your team can run it.
        </p>
        <div class="step-outcome-block">
          <p class="step-outcome">&gt; OUTCOME: Production-ready. Documented. Tested. Deployed.</p>
          <p class="step-comment">// Simple sites ship in under a week. Apps start at two weeks.</p>
        </div>
      </div>
    </li>

    <!-- Step 03: RESULTS -->
    <li class="step">
      <div class="step-node-area" aria-hidden="true">
        <span class="step-num-label">Step 03</span>
        <div class="step-node">03</div>
      </div>
      <div class="step-content">
        <h3 class="step-title">RESULTS</h3>
        <p class="step-body">
          Thirty days of post-launch support. Then the Handoff Package arrives:
          your code, your hosting credentials, your CMS instructions, and the
          original Problem Statement. You own everything. Nothing is locked to us.
        </p>
        <div class="step-outcome-block">
          <p class="step-outcome">&gt; OUTCOME: The Handoff Package. Your code, your system, complete ownership.</p>
          <p class="step-comment">// Most projects ship in 30 to 90 days.</p>
        </div>
      </div>
    </li>
  </ol>
  </div>

  <!-- CTA -->
  <div class="process-cta">
    <Button variant="ghost" href="/diagnostic">[RUN THE FREE DIAGNOSTIC &gt;]</Button>
    <Button variant="primary" href="#diagnostic">[START YOUR PROJECT &gt;]</Button>
  </div>
</SectionWrapper>

<style>
  /* Amber divider rule at top */
  .process-divider {
    height: 1px;
    background: var(--border);
  }

  /* Warm gradient background — !important overrides SectionWrapper inline style */
  :global(.process-section) {
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg-plan-end) 100%) !important;
  }

  /* Section label */
  .section-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-accent-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  /* Headline - Geist Sans, two lines */
  .process-headline {
    font-family: var(--font-sans);
    font-size: var(--step-4);
    line-height: 1.15;
    letter-spacing: var(--tracking-snug);
    color: var(--text);
    margin-bottom: var(--space-16);
  }

  .process-headline span {
    display: block;
  }

  .process-headline span:first-child {
    color: var(--primary);
  }

  .process-headline span:last-child {
    color: oklch(0.76 0.18 62 / 0.7);
  }

  /* ── Pipeline wrapper (positioning context for the decorative line) ── */
  .pipeline-wrapper {
    position: relative;
    margin-bottom: var(--space-16);
  }

  /* ── Pipeline layout ── */
  .pipeline {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-10);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Horizontal connecting line (desktop) */
  .pipeline-line {
    position: absolute;
    top: 38px;
    left: 12px;
    right: 12px;
    height: 2px;
    background: var(--primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1.8s var(--ease-phosphor);
  }

  .pipeline-wrapper.revealed .pipeline-line {
    transform: scaleX(1);
  }

  /* ── Step ── */
  .step {
    position: relative;
    z-index: 1;
  }

  .step-node-area {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: var(--space-6);
  }

  .step-num-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-feature-settings: 'tnum' 1;
    color: var(--text-accent-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .step-node {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--primary);
    color: var(--bg-dark);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 700;
    font-feature-settings: 'tnum' 1;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-title {
    font-family: var(--font-pixel);
    font-size: var(--step-2);
    line-height: 1.25;
    color: var(--amber-4);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-4);
  }

  .step-body {
    font-family: var(--font-sans);
    font-size: var(--step-0);
    line-height: 1.65;
    color: oklch(0.88 0.06 62);
    margin-bottom: var(--space-5);
    max-width: var(--measure-normal);
  }

  /* Outcome block */
  .step-outcome-block {
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-muted);
  }

  .step-outcome {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-feature-settings: 'tnum' 1;
    color: var(--success);
    line-height: 1.5;
    margin-bottom: var(--space-2);
  }

  .step-comment {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--amber-2);
    line-height: 1.5;
  }

  /* ── CTA area ── */
  .process-cta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ── Responsive: mobile ── */
  @media (max-width: 768px) {
    .process-headline {
      font-size: var(--step-3);
    }

    /* Stack vertically with left-edge pipeline */
    .pipeline {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      padding-left: var(--space-10);
    }

    /* Vertical pipeline line on left edge */
    .pipeline-line {
      top: 16px;
      bottom: 16px;
      left: 12px;
      right: auto;
      width: 2px;
      height: auto;
      transform: scaleY(0);
      transform-origin: top;
    }

    .pipeline-wrapper.revealed .pipeline-line {
      transform: scaleY(1);
    }

    /* Node area: row layout, node on left edge */
    .step {
      position: relative;
    }

    .step-node-area {
      position: absolute;
      left: calc(-1 * var(--space-10));
      top: 0;
      align-items: center;
    }

    .step-title {
      font-size: var(--step-1);
    }

    .process-cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .process-headline {
      font-size: var(--step-2);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .pipeline-line {
      transition: none;
      transform: scaleX(1);
    }
  }

  @media (prefers-reduced-motion: reduce) and (max-width: 768px) {
    .pipeline-line {
      transform: scaleY(1);
    }
  }
</style>
