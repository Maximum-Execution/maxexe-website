---
import SectionWrapper from '../SectionWrapper.astro';
import Button from '../Button.astro';
---
<SectionWrapper id="process" theme="light">
  <!-- Section label -->
  <p class="section-label section-label--light">// 05 THE PLAN</p>

  <!-- Intro headline -->
  <h2 class="process-headline">
    <span>How it works.</span>
    <span>Three steps.</span>
  </h2>

  <!-- Pipeline -->
  <div class="pipeline-wrapper" data-animate>
    <!-- Pipeline connecting line (desktop: horizontal, mobile: vertical) -->
    <div class="pipeline-line" aria-hidden="true"></div>
    <ol class="pipeline">
    <!-- Step 01: CLARITY -->
    <li class="step">
      <div class="step-node-area" aria-hidden="true">
        <span class="step-num-label">Step 01</span>
        <div class="step-node">01</div>
      </div>
      <div class="step-content">
        <h3 class="step-title">CLARITY</h3>
        <p class="step-body">
          The diagnostic is free. I map what's broken across your message, your
          site, and your tools. Then I write the Problem Statement in plain
          language: exactly what's broken and what the fix looks like. You read
          it. You sign off. No code gets written until you do.
        </p>
        <div class="step-outcome-block">
          <p class="step-outcome">&gt; OUTCOME: A written diagnosis in plain language. You verify it before anything is built.</p>
          <p class="step-comment">// The diagnostic takes five minutes. It's free.</p>
        </div>
      </div>
    </li>

    <!-- Step 02: CODE -->
    <li class="step">
      <div class="step-node-area" aria-hidden="true">
        <span class="step-num-label">Step 02</span>
        <div class="step-node">02</div>
      </div>
      <div class="step-content">
        <h3 class="step-title">CODE</h3>
        <p class="step-body">
          One person builds your project from start to finish. Not a team with a
          project manager between you and the work. Not a template reskinned as
          something custom. Production-ready code with full documentation so you
          can run it without me.
        </p>
        <div class="step-outcome-block">
          <p class="step-outcome">&gt; OUTCOME: Your operating system, built and deployed.</p>
          <p class="step-comment">// Simple sites ship in under a week. App projects start at two weeks.</p>
        </div>
      </div>
    </li>

    <!-- Step 03: RESULTS -->
    <li class="step">
      <div class="step-node-area" aria-hidden="true">
        <span class="step-num-label">Step 03</span>
        <div class="step-node">03</div>
      </div>
      <div class="step-content">
        <h3 class="step-title">RESULTS</h3>
        <p class="step-body">
          Thirty days of post-launch support included. Then the Handoff Package:
          your code, your hosting credentials, your CMS instructions, and the
          original Problem Statement. You own everything. Nothing is locked to
          MAX.EXE.
        </p>
        <div class="step-outcome-block">
          <p class="step-outcome">&gt; OUTCOME: Complete ownership. Nothing owed after launch.</p>
          <p class="step-comment">// Most projects ship in 30 to 90 days.</p>
        </div>
      </div>
    </li>
  </ol>
  </div>

  <!-- CTA -->
  <div class="process-cta">
    <Button variant="ghost" href="/diagnostic">[GET YOUR FREE DIAGNOSTIC &gt;]</Button>
    <Button variant="primary" href="#diagnostic">[START YOUR PROJECT &gt;]</Button>
  </div>
</SectionWrapper>

<style>
  /* Headline - Geist Sans, two lines */
  .process-headline {
    font-family: var(--font-sans);
    font-size: var(--step-4);
    line-height: 1.15;
    letter-spacing: var(--tracking-snug);
    color: var(--text);
    margin-bottom: var(--space-16);
  }

  .process-headline span {
    display: block;
  }

  /* ── Pipeline wrapper (positioning context for the decorative line) ── */
  .pipeline-wrapper {
    position: relative;
    margin-bottom: var(--space-16);
  }

  /* ── Pipeline layout ── */
  .pipeline {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-10);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Horizontal connecting line (desktop) */
  .pipeline-line {
    position: absolute;
    top: 38px;
    left: 12px;
    right: 12px;
    height: 2px;
    background: var(--primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1.8s var(--ease-phosphor);
  }

  .pipeline-wrapper.revealed .pipeline-line {
    transform: scaleX(1);
  }

  /* ── Step ── */
  .step {
    position: relative;
    z-index: 1;
  }

  .step-node-area {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: var(--space-6);
  }

  .step-num-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-feature-settings: 'tnum' 1;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .step-node {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--primary);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 700;
    font-feature-settings: 'tnum' 1;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-title {
    font-family: var(--font-pixel);
    font-size: var(--step-2);
    line-height: 1.25;
    color: var(--text);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-4);
  }

  .step-body {
    font-family: var(--font-sans);
    font-size: var(--step-0);
    line-height: 1.65;
    color: var(--text-muted);
    margin-bottom: var(--space-5);
    max-width: var(--measure-normal);
  }

  /* Outcome block */
  .step-outcome-block {
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-muted);
  }

  .step-outcome {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-feature-settings: 'tnum' 1;
    color: var(--success);
    line-height: 1.5;
    margin-bottom: var(--space-2);
  }

  .step-comment {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* ── CTA area ── */
  .process-cta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ── Responsive: mobile ── */
  @media (max-width: 768px) {
    .process-headline {
      font-size: var(--step-3);
    }

    /* Stack vertically with left-edge pipeline */
    .pipeline {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      padding-left: var(--space-10);
    }

    /* Vertical pipeline line on left edge */
    .pipeline-line {
      top: 16px;
      bottom: 16px;
      left: 12px;
      right: auto;
      width: 2px;
      height: auto;
      transform: scaleY(0);
      transform-origin: top;
    }

    .pipeline-wrapper.revealed .pipeline-line {
      transform: scaleY(1);
    }

    /* Node area: row layout, node on left edge */
    .step {
      position: relative;
    }

    .step-node-area {
      position: absolute;
      left: calc(-1 * var(--space-10));
      top: 0;
      align-items: center;
    }

    .step-title {
      font-size: var(--step-1);
    }

    .process-cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .process-headline {
      font-size: var(--step-2);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .pipeline-line {
      transition: none;
      transform: scaleX(1);
    }
  }

  @media (prefers-reduced-motion: reduce) and (max-width: 768px) {
    .pipeline-line {
      transform: scaleY(1);
    }
  }
</style>
