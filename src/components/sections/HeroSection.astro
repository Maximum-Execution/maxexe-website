---
import Button from '../Button.astro';
---
<section class="hero theme-dark" id="hero">
  <div class="hero-inner">
    <p class="hero-intro">
      <span>// Maximum Execution · Richmond, VA</span>
      <span>// Web Design · Apps · AI Tools</span>
    </p>

    <h1 class="hero-headline">
      <span class="line-1">Your business is better than</span>
      <span class="line-2">your website says it is.</span>
    </h1>

    <p class="hero-subhead">
      You know your work is good. Strangers can't tell.
      I diagnose what's broken and build the system that fixes it.
    </p>

    <p class="hero-tagline">// Clarity. Code. Results.</p>

    <div class="hero-ctas">
      <Button variant="primary" href="#diagnostic">[START YOUR PROJECT &gt;]</Button>
      <Button variant="ghost" href="/diagnostic">[GET YOUR FREE DIAGNOSTIC &gt;]</Button>
    </div>
  </div>
</section>

<style>
  .hero {
    height: calc(100dvh - 55px);       /* CONSTRAIN to viewport minus sticky topbar (44px min-h + padding + border) */
    display: flex;
    flex-direction: column;
    padding: var(--space-8);
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-inner {
    max-width: var(--measure-wide);
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-intro {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-muted);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 0.15em;
  }

  .hero-headline {
    font-family: var(--font-pixel);
    font-size: var(--step-4);           /* down from --step-5 */
    line-height: 1.1;
    letter-spacing: var(--tracking-snug);
    margin-bottom: var(--space-5);      /* 20px, down from 32px */
  }

  .hero-headline .line-1,
  .hero-headline .line-2 {
    display: block;
    color: var(--text);
  }

  .hero-subhead {
    font-family: var(--font-sans);
    font-size: var(--step-0);           /* down from --step-1 */
    color: var(--text-muted);
    line-height: 1.55;
    max-width: var(--measure-normal);
    margin-bottom: var(--space-4);      /* 16px, down from 24px */
  }

  .hero-tagline {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-muted);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-5);      /* 20px, down from 32px */
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* Tablet */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-6) var(--space-5);
    }

    .hero-headline {
      font-size: var(--step-3);
    }

    .hero-ctas {
      flex-direction: column;
    }

    .hero-ctas :global(.btn) {
      width: 100%;
      justify-content: center;
    }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .hero {
      padding: var(--space-5) var(--space-4);
    }

    .hero-intro {
      margin-bottom: var(--space-3);
    }

    .hero-headline {
      font-size: var(--step-2);         /* 24-28px — readable pixel font on small screens */
      margin-bottom: var(--space-4);
    }

    .hero-subhead {
      font-size: var(--step--1);
      margin-bottom: var(--space-3);
    }

    .hero-tagline {
      margin-bottom: var(--space-4);
    }
  }
</style>
