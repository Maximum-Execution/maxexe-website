---
import Button from '../Button.astro';
---
<section class="hero theme-dark" id="hero">
  <div class="hero-bg-glow" aria-hidden="true"></div>
  <div class="hero-inner">
    <p class="hero-intro">
      <span>// Maximum Execution · Richmond, VA</span>
      <span>// Web Design · Apps · AI Tools</span>
    </p>

    <h1 class="hero-headline crt-live">
      <span class="line-1 hero-glitch" data-text="Your business is better than">Your business is better than</span>
      <span class="line-2">your website says it is.</span>
    </h1>

    <p class="hero-subhead glow">
      You know your work is good. Strangers can't tell.
      I diagnose what's broken and build the system that fixes it.
    </p>

    <p class="hero-tagline">// Clarity. Code. Results.</p>

    <div class="hero-ctas">
      <Button variant="primary" href="#diagnostic">[START YOUR PROJECT &gt;]</Button>
      <Button variant="ghost" href="/diagnostic">[GET YOUR FREE DIAGNOSTIC &gt;]</Button>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100dvh - 44px);  /* fills remaining viewport after 44px sticky topbar */
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-10) var(--space-8);  /* symmetric — topbar handles its own 44px */
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-bg-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    max-width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, oklch(0.76 0.18 62 / 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: var(--measure-wide);
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .hero-intro {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-muted);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: 0.25em;
  }

  .hero-headline {
    font-family: var(--font-pixel);
    font-size: var(--step-5);
    line-height: 1.1;
    letter-spacing: var(--tracking-snug);
    margin-bottom: var(--space-8);
  }

  .hero-headline .line-1,
  .hero-headline .line-2 {
    display: block;
    color: var(--text);
  }

  .hero-subhead {
    font-family: var(--font-sans);
    font-size: var(--step-1);
    color: var(--text-muted);
    line-height: 1.65;
    max-width: var(--measure-normal);
    margin-bottom: var(--space-6);
  }

  .hero-tagline {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-muted);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-8);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-8) var(--space-6);
    }

    .hero-headline {
      font-size: var(--step-3);
    }

    .hero-ctas {
      flex-direction: column;
    }

    .hero-ctas :global(.btn) {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: var(--space-6) var(--space-5);
    }

    .hero-headline {
      font-size: var(--step-4);
    }

    .hero-subhead {
      font-size: var(--step--1);
    }
  }
</style>
