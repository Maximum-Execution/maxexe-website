---
import Button from '../Button.astro';
import GlassCard from '../GlassCard.astro';
import Cursor from '../Cursor.astro';
---
<section class="hero" id="hero">
  <div class="hero-bg-glow" aria-hidden="true"></div>
  <div class="hero-inner">
    <!-- Left Column -->
    <div class="hero-content">
      <p class="hero-intro">// Maximum Execution · Richmond, VA · Web Design · Apps · AI Tools</p>

      <h1 class="hero-headline">
        <span class="line-1">Your business is better than</span>
        <span class="line-2">your website says it is.</span>
      </h1>

      <p class="hero-subhead">
        We find what's broken in your message, your tools, or your workflow.
        Then we build the fix.
      </p>

      <p class="hero-tagline">// Clarity. Code. Results.</p>

      <div class="hero-ctas">
        <Button variant="primary" href="#diagnostic">[START YOUR PROJECT &gt;]</Button>
        <Button variant="ghost" href="/diagnostic">[RUN THE FREE DIAGNOSTIC &gt;]</Button>
      </div>
    </div>

    <!-- Right Column -->
    <div class="hero-terminal">
      <GlassCard>
        <div class="terminal-bar">
          <span class="dot g"></span>
          <span class="terminal-label">max.exe // system status v2.0.0</span>
        </div>
        <div class="terminal-rule"></div>
        <dl class="status-list">
          <div class="status-line">
            <dt class="status-text"><span class="status-badge ok" aria-hidden="true">[OK]</span>Businesses served:</dt>
            <dd class="status-value">12+</dd>
          </div>
          <div class="status-line">
            <dt class="status-text"><span class="status-badge ok" aria-hidden="true">[OK]</span>Deadlines missed:</dt>
            <dd class="status-value">0</dd>
          </div>
          <div class="status-line">
            <dt class="status-text"><span class="status-badge ok" aria-hidden="true">[OK]</span>Code ownership at delivery:</dt>
            <dd class="status-value">100%</dd>
          </div>
          <div class="status-line">
            <dt class="status-text"><span class="status-badge ok" aria-hidden="true">[OK]</span>Client intake:</dt>
            <dd class="status-value">OPEN // 2 of 3 slots</dd>
          </div>
          <div class="status-line">
            <dt class="status-text"><span class="status-badge ok" aria-hidden="true">[OK]</span>Avg response time:</dt>
            <dd class="status-value">&lt; 24hr</dd>
          </div>
        </dl>
        <div class="status-line prompt-line">
          <span class="prompt">&gt;_</span>
          <span class="ready">[READY]</span>
          <Cursor />
        </div>
      </GlassCard>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 85dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-24) var(--space-8);
    position: relative;
    overflow: hidden;
    background: var(--crt-black);
  }

  .hero-bg-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    max-width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, oklch(0.76 0.18 62 / 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: var(--container-xl);
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
    position: relative;
    z-index: 2;
  }

  /* Override DaisyUI .hero-content which sets display:flex */
  .hero-content {
    display: block;
  }

  .hero-intro {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--amber-3);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-6);
  }

  .hero-headline {
    font-family: var(--font-pixel);
    font-size: var(--step-4);
    line-height: 1.1;
    letter-spacing: var(--tracking-snug);
    margin-bottom: var(--space-8);
  }

  .hero-headline .line-1 {
    display: block;
    color: var(--text);
  }

  .hero-headline .line-2 {
    display: block;
    color: var(--text);
  }

  .hero-subhead {
    font-family: var(--font-mono);
    font-size: var(--step-0);
    color: var(--text-muted);
    line-height: 1.65;
    max-width: var(--measure-normal);
    margin-bottom: var(--space-6);
  }

  .hero-tagline {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--amber-3);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-8);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* Terminal widget */
  .hero-terminal {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-muted);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .dot.g {
    background: var(--success);
    box-shadow: 0 0 6px var(--success);
  }

  .terminal-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }

  .terminal-rule {
    height: 1px;
    background: var(--border-muted);
    margin-bottom: var(--space-4);
  }

  .status-list {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-feature-settings: 'tnum' 1;
  }

  .status-line {
    display: flex;
    gap: var(--space-2);
    padding: var(--space-1) 0;
    align-items: baseline;
  }

  .status-badge {
    flex-shrink: 0;
    font-weight: 600;
  }
  .status-badge.ok {
    color: var(--success);
    text-shadow: 0 0 4px oklch(0.70 0.18 160 / 0.9), 0 0 8px oklch(0.70 0.18 160 / 0.35);
  }

  .status-text {
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
    color: var(--text-muted);
    flex: 1;
  }

  .status-value {
    color: var(--text);
    text-align: right;
  }

  .prompt-line {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-feature-settings: 'tnum' 1;
    margin-top: var(--space-2);
    padding-top: var(--space-2);
    border-top: 1px solid var(--border-muted);
  }

  .prompt {
    color: var(--primary);
  }

  .ready {
    color: var(--success);
    text-shadow: 0 0 4px oklch(0.70 0.18 160 / 0.9);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-16) var(--space-6);
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .hero-content,
    .hero-terminal {
      min-width: 0;
      overflow: hidden;
    }

    .hero-headline {
      font-size: var(--step-3);
    }

    .status-line {
      flex-wrap: wrap;
    }

    .status-text {
      white-space: normal;
    }

    .status-value {
      margin-left: 0;
      padding-left: var(--space-4);
    }

    .hero-ctas {
      flex-direction: column;
    }

    .hero-ctas :global(.btn) {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .hero-headline {
      font-size: var(--step-2);
    }
  }
</style>
