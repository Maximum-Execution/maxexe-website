---
import SectionWrapper from '../SectionWrapper.astro';
import BruteCard from '../BruteCard.astro';
import Badge from '../Badge.astro';
import Button from '../Button.astro';
import SystemScanInfographic from '../infographics/SystemScanInfographic.astro';
---
<div class="stakes-divider" aria-hidden="true"></div>
<SectionWrapper bg="base" id="stakes" class="stakes-section">
  <!-- Section label -->
  <p class="section-label">// 02 THE STAKES</p>

  <!-- Headline -->
  <h2 class="stakes-headline">
    <span>Your work earns trust.</span>
    <span>Your website should too.</span>
  </h2>

  <!-- Body copy -->
  <div class="stakes-body">
    <p>
      Prospects visit your site. They can't figure out what you offer. They
      leave. Someone with a worse product, but a clearer message, gets the call
      instead.
    </p>

    <p>
      You already know this. That quiet dread when you send someone to your
      site, wondering if it'll make you look smaller than you are. That's not a
      feeling. That's a signal.
    </p>

    <p>
      Good work deserves to be found. Bad marketing shouldn't be a tax on good
      work.
    </p>
  </div>

  <!-- Root cause -->
  <p class="root-cause">// ROOT CAUSE IDENTIFIED &gt; VILLAIN: FRAGMENTATION</p>

  <!-- [ERR] cards -->
  <div class="err-grid">
    <BruteCard>
      <Badge variant="err">[ERR]</Badge>
      <h3 class="err-title">CREDIBILITY PROBLEM</h3>
      <p class="err-desc">Your site forms an impression in 50 milliseconds. Before anyone reads a word.</p>
      <p class="err-source">// Lindgaard et al., 2006</p>
    </BruteCard>

    <BruteCard>
      <Badge variant="err">[ERR]</Badge>
      <h3 class="err-title">CONFIDENCE PROBLEM</h3>
      <p class="err-desc">4 out of 5 small business owners are not confident their marketing is working.</p>
      <p class="err-source">// Constant Contact / Ascend2, 2025 · n=2,500</p>
    </BruteCard>

    <BruteCard>
      <Badge variant="err">[ERR]</Badge>
      <h3 class="err-title">REFERRAL PROBLEM</h3>
      <p class="err-desc">57% of people won't recommend a business with a poorly designed mobile site.</p>
      <p class="err-source">// networksolutions.com / multiple sources, 2025</p>
    </BruteCard>
  </div>

  <!-- CTA -->
  <div class="stakes-cta">
    <Button variant="ghost" href="/diagnostic">[RUN THE FREE DIAGNOSTIC &gt;]</Button>
    <p class="cta-comment">// Five minutes tells you exactly what's broken.</p>
  </div>

  <SystemScanInfographic />
</SectionWrapper>

<style>
  /* Amber divider rule between hero and stakes */
  .stakes-divider {
    height: 1px;
    background: oklch(0.76 0.18 62 / 0.15);
  }

  /* Section label - monospace, small */
  .section-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-accent-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  /* Headline - Geist Pixel, two lines */
  .stakes-headline {
    font-family: var(--font-pixel);
    font-size: var(--step-4);
    line-height: 1.15;
    letter-spacing: var(--tracking-snug);
    color: var(--text);
    margin-bottom: var(--space-10);
  }

  .stakes-headline span {
    display: block;
  }

  .stakes-headline span:first-child {
    color: var(--primary);
  }

  .stakes-headline span:last-child {
    color: oklch(0.76 0.18 62 / 0.7);
  }

  /* Body copy */
  .stakes-body {
    max-width: var(--measure-normal);
    margin-bottom: var(--space-10);
  }

  .stakes-body p {
    font-family: var(--font-sans);
    font-size: var(--step-0);
    line-height: 1.65;
    color: oklch(0.88 0.06 62);
    margin-bottom: var(--space-6);
  }

  .stakes-body p:last-child {
    margin-bottom: 0;
  }

  /* Root cause line */
  .root-cause {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--danger);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-12);
    text-shadow: 0 0 4px oklch(0.70 0.18 30 / 0.5);
  }

  /* [ERR] card grid */
  .err-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-12);
  }

  /* Override BruteCard default colors for [ERR] cards */
  .err-grid :global(.brute-card) {
    background: var(--bg-stakes-err);
    border-color: var(--bg-stakes-border);
    box-shadow: 4px 4px 0 0 oklch(0.28 0.12 30 / 0.4);
  }

  .err-grid :global(.brute-card:hover) {
    border-color: var(--danger);
    box-shadow: 6px 6px 0 0 var(--danger);
  }

  /* Card internals */
  .err-title {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .err-desc {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: var(--space-4);
  }

  .err-source {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-accent-dim);
    line-height: 1.4;
    font-feature-settings: 'tnum' 1;
    padding-top: var(--space-3);
    border-top: 1px solid var(--bg-stakes-border);
  }

  /* CTA area */
  .stakes-cta {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .cta-comment {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--text-accent-dim);
    letter-spacing: 0.06em;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .stakes-headline {
      font-size: var(--step-3);
    }

    .err-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .stakes-cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .stakes-headline {
      font-size: var(--step-2);
    }
  }
</style>
