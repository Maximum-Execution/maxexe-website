---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<span class:list={['cursor', className]} aria-hidden="true">_</span>

<style>
  .cursor {
    display: inline-block;
    color: var(--primary);
    font-weight: bold;
    vertical-align: text-bottom;
    animation: hw-blink var(--dur-cursor) step-end infinite;
  }
</style>
