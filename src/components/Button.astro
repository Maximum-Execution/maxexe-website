---
interface Props {
  variant?: 'primary' | 'ghost';
  href?: string;
  class?: string;
  type?: 'button' | 'submit';
}
const { variant = 'primary', href, class: className, type = 'button' } = Astro.props;
---
{href ? (
  <a href={href} class:list={['btn', `btn-${variant}`, className]}>
    <slot />
  </a>
) : (
  <button type={type} class:list={['btn', `btn-${variant}`, className]}>
    <slot />
  </button>
)}

<style>
  .btn {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-feature-settings: 'tnum' 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: var(--space-3) var(--space-6);
    border: 1px solid;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    border-radius: var(--radius-sm);
    transition: background var(--dur-micro) var(--ease-ui),
                border-color var(--dur-micro) var(--ease-ui),
                color var(--dur-micro) var(--ease-ui),
                box-shadow var(--dur-micro) var(--ease-ui),
                transform var(--dur-micro) var(--ease-ui);
  }
  .btn-primary {
    background: var(--primary);
    border-color: var(--primary);
    color: var(--bg-dark);
    font-weight: 700;
  }
  .btn-primary:hover {
    background: oklch(0.82 0.18 62);
    border-color: oklch(0.82 0.18 62);
    box-shadow: 0 0 16px oklch(0.76 0.18 62 / 0.4);
    transform: translateY(-1px);
  }
  .btn-primary:active {
    background: oklch(0.68 0.19 58);
    transform: translateY(1px);
    box-shadow: none;
  }
  .btn-ghost {
    background: transparent;
    border-color: var(--border);
    color: var(--primary);
  }
  .btn-ghost:hover {
    border-color: var(--primary);
    box-shadow: 0 0 8px oklch(0.76 0.18 62 / 0.25);
  }

  .btn:focus-visible {
    outline: 2px solid oklch(0.76 0.18 62);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .btn {
      max-width: 100%;
      text-align: center;
      justify-content: center;
      font-size: var(--step--2);
      padding: var(--space-3) var(--space-4);
      word-break: break-word;
    }
  }
</style>
