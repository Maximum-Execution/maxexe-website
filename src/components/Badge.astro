---
interface Props {
  variant?: 'amber' | 'ok' | 'warn' | 'err' | 'info';
  class?: string;
}
const { variant = 'amber', class: className } = Astro.props;

const colorMap = {
  amber: 'var(--primary)',
  ok: 'var(--success)',
  warn: 'var(--warning)',
  err: 'var(--danger)',
  info: 'var(--info)',
};
---
<span class:list={['badge', className]} style={`color: ${colorMap[variant]};`}>
  <slot />
</span>

<style>
  .badge {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: var(--space-1) var(--space-3);
    border: 1px solid currentColor;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    min-height: 26px;
  }
</style>
