---
// EighteenMonthTrapInfographic.astro
// Timeline infographic showing the 18-month software regret progression
// Animation: CSS transitions triggered by Intersection Observer
---

<div class="trap-infographic" data-infographic>
  <div class="timeline-wrapper">
    <div class="timeline-bar" aria-hidden="true"></div>
    <div class="timeline-markers">

      <div class="marker marker-0">
        <span class="month-label">MONTH 0</span>
        <div class="node node-ok" aria-hidden="true"></div>
        <span class="badge badge-ok">[OK]</span>
        <span class="phase-title">PURCHASE</span>
        <p class="descriptor">"Demo looks great. Features check out. Price seems fine."</p>
      </div>

      <div class="marker marker-6">
        <span class="month-label">MONTH 6</span>
        <div class="node node-warn" aria-hidden="true"></div>
        <span class="badge badge-warn">[WARN]</span>
        <span class="phase-title">REALITY</span>
        <p class="descriptor">"Setup harder than expected. Team not adopting it. Nothing integrates."</p>
      </div>

      <div class="marker marker-18">
        <span class="month-label">MONTH 18</span>
        <div class="node node-err" aria-hidden="true"></div>
        <span class="badge badge-err">[ERR]</span>
        <span class="phase-title">REGRET</span>
        <p class="descriptor">"Still paying. 80% of features unused."</p>
        <p class="stat-line">
          <span class="stat-number">60%</span> of software buyers are here.
        </p>
        <span class="stat-source">// Gartner, 2023</span>
      </div>

    </div>
  </div>
  <p class="trap-caption">"You didn't buy the wrong software. You bought before you ran a diagnosis."</p>
</div>

<script>
  function initTrapInfographic() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const infographics = document.querySelectorAll<HTMLElement>('[data-infographic]');

    infographics.forEach((infographic) => {
      if (prefersReducedMotion) {
        infographic.classList.add('visible');
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              infographic.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.3 }
      );

      observer.observe(infographic);
    });
  }

  // Run on initial load
  initTrapInfographic();

  // Re-run after Astro client-side navigation
  document.addEventListener('astro:after-swap', initTrapInfographic);
</script>

<style>
  /* ------------------------------------------------
     Layout
  ------------------------------------------------ */
  .trap-infographic {
    max-width: 700px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .timeline-wrapper {
    position: relative;
    padding-top: 1.5rem;
  }

  /* ------------------------------------------------
     Timeline bar — horizontal (desktop)
  ------------------------------------------------ */
  .timeline-bar {
    position: absolute;
    top: calc(1.5rem + 1rem + 5px);
    /* 1.5rem padding-top + ~1rem month-label height + half node */
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(to right, var(--success), var(--danger));
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 500ms linear;
  }

  .trap-infographic.visible .timeline-bar {
    transform: scaleX(1);
  }

  /* ------------------------------------------------
     Marker grid — 3 columns (desktop)
  ------------------------------------------------ */
  .timeline-markers {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    position: relative;
  }

  /* ------------------------------------------------
     Individual marker
  ------------------------------------------------ */
  .marker {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .marker-0 {
    align-items: flex-start;
  }

  .marker-6 {
    align-items: center;
    text-align: center;
  }

  .marker-18 {
    align-items: flex-end;
    text-align: right;
  }

  /* ------------------------------------------------
     Month label
  ------------------------------------------------ */
  .month-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--amber-2);
    margin-bottom: 0.35rem;
    opacity: 0;
    transition: opacity 150ms ease-out;
  }

  /* ------------------------------------------------
     Node circle
  ------------------------------------------------ */
  .node {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 150ms ease-out;
  }

  .node-ok {
    background: var(--success);
  }

  .node-warn {
    background: oklch(0.78 0.18 90);
  }

  .node-err {
    background: var(--danger);
  }

  /* ------------------------------------------------
     Badge
  ------------------------------------------------ */
  .badge {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    margin-top: 0.5rem;
    opacity: 0;
    transition: opacity 150ms ease-out;
  }

  .badge-ok {
    color: var(--success);
  }

  .badge-warn {
    color: oklch(0.78 0.18 90);
  }

  .badge-err {
    color: var(--danger);
  }

  /* ------------------------------------------------
     Phase title
  ------------------------------------------------ */
  .phase-title {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    margin-top: 0.2rem;
    opacity: 0;
    transition: opacity 150ms ease-out;
  }

  /* ------------------------------------------------
     Descriptor quote
  ------------------------------------------------ */
  .descriptor {
    font-family: var(--font-mono);
    font-size: 12px;
    font-style: italic;
    color: var(--text-muted);
    margin: 0.35rem 0 0 0;
    line-height: 1.5;
    opacity: 0;
    transition: opacity 150ms ease-out;
  }

  /* ------------------------------------------------
     Stat callout (Month 18 only)
  ------------------------------------------------ */
  .stat-line {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    margin: 0.6rem 0 0 0;
    line-height: 1.5;
    opacity: 0;
    transition: opacity 150ms ease-out;
  }

  .stat-number {
    color: var(--amber-4);
    font-weight: 700;
  }

  .stat-source {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-accent-dim);
    opacity: 0;
    transition: opacity 150ms ease-out;
  }

  /* ------------------------------------------------
     Caption
  ------------------------------------------------ */
  .trap-caption {
    font-family: var(--font-mono);
    font-size: 13px;
    font-style: italic;
    color: var(--amber-2);
    text-align: center;
    margin: 2rem 0 0 0;
    opacity: 0;
    transition: opacity 150ms ease-out;
  }

  /* ------------------------------------------------
     Animation sequence — visible state
     Bar draws over 500ms.
     Marker 0 node at 0ms, text at +150ms
     Marker 6 node at ~170ms, text at +150ms (320ms)
     Marker 18 node at ~340ms, text at +150ms (490ms)
     Stat line: 490ms + 400ms = 890ms
     Caption: after stat
  ------------------------------------------------ */

  /* Month labels appear with their nodes */
  .trap-infographic.visible .marker-0 .month-label {
    opacity: 1;
    transition-delay: 0ms;
  }

  .trap-infographic.visible .marker-6 .month-label {
    opacity: 1;
    transition-delay: 170ms;
  }

  .trap-infographic.visible .marker-18 .month-label {
    opacity: 1;
    transition-delay: 340ms;
  }

  /* Nodes */
  .trap-infographic.visible .marker-0 .node {
    opacity: 1;
    transition-delay: 0ms;
  }

  .trap-infographic.visible .marker-6 .node {
    opacity: 1;
    transition-delay: 170ms;
  }

  .trap-infographic.visible .marker-18 .node {
    opacity: 1;
    transition-delay: 340ms;
  }

  /* Badges — 150ms after respective node */
  .trap-infographic.visible .marker-0 .badge {
    opacity: 1;
    transition-delay: 150ms;
  }

  .trap-infographic.visible .marker-6 .badge {
    opacity: 1;
    transition-delay: 320ms;
  }

  .trap-infographic.visible .marker-18 .badge {
    opacity: 1;
    transition-delay: 490ms;
  }

  /* Phase titles — same delay as badges */
  .trap-infographic.visible .marker-0 .phase-title {
    opacity: 1;
    transition-delay: 150ms;
  }

  .trap-infographic.visible .marker-6 .phase-title {
    opacity: 1;
    transition-delay: 320ms;
  }

  .trap-infographic.visible .marker-18 .phase-title {
    opacity: 1;
    transition-delay: 490ms;
  }

  /* Descriptors — same delay as badges */
  .trap-infographic.visible .marker-0 .descriptor {
    opacity: 1;
    transition-delay: 150ms;
  }

  .trap-infographic.visible .marker-6 .descriptor {
    opacity: 1;
    transition-delay: 320ms;
  }

  .trap-infographic.visible .marker-18 .descriptor {
    opacity: 1;
    transition-delay: 490ms;
  }

  /* Stat line — 400ms AFTER Month 18 text (490 + 400 = 890ms) */
  .trap-infographic.visible .stat-line {
    opacity: 1;
    transition-delay: 890ms;
  }

  .trap-infographic.visible .stat-source {
    opacity: 1;
    transition-delay: 890ms;
  }

  /* Caption — after stat */
  .trap-infographic.visible .trap-caption {
    opacity: 1;
    transition-delay: 1050ms;
  }

  /* ------------------------------------------------
     prefers-reduced-motion: show everything at once
  ------------------------------------------------ */
  @media (prefers-reduced-motion: reduce) {
    .timeline-bar {
      transform: scaleX(1);
      transition: none;
    }

    .month-label,
    .node,
    .badge,
    .phase-title,
    .descriptor,
    .stat-line,
    .stat-source,
    .trap-caption {
      opacity: 1;
      transition: none;
    }
  }

  /* ------------------------------------------------
     Responsive — vertical timeline on mobile
  ------------------------------------------------ */
  @media (max-width: 767px) {
    .timeline-wrapper {
      padding-top: 0;
      padding-left: 2rem;
    }

    /* Vertical bar on the left */
    .timeline-bar {
      top: 0;
      bottom: 0;
      left: 5px;
      right: auto;
      width: 3px;
      height: auto;
      background: linear-gradient(to bottom, var(--success), var(--danger));
      transform-origin: top center;
      transform: scaleY(0);
    }

    .trap-infographic.visible .timeline-bar {
      transform: scaleY(1);
    }

    @media (prefers-reduced-motion: reduce) {
      .timeline-bar {
        transform: scaleY(1);
      }
    }

    /* Stack markers vertically */
    .timeline-markers {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .marker {
      align-items: flex-start;
      text-align: left;
      position: relative;
    }

    .marker-6,
    .marker-18 {
      align-items: flex-start;
      text-align: left;
    }

    /* Position node circles on the vertical bar */
    .node {
      position: absolute;
      left: calc(-2rem + -1px);
      /* Center on the 3px bar: -(padding-left) + (bar-width/2 - node-width/2) */
      top: 1.1rem;
    }

    .trap-caption {
      text-align: left;
      padding-left: 0;
    }
  }
</style>
