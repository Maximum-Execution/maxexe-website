---
// SystemScanInfographic.astro
// Terminal-style animated infographic that "scans" business systems.
// Lines type in sequentially when scrolled into view via Intersection Observer.
---

<div class="scan-infographic" data-infographic>
  <div class="scan-terminal">
    <span class="scan-line prompt-line" data-line="0">&gt; SCANNING BUSINESS SYSTEMS...</span>
    <span class="scan-line divider-line" data-line="1">&gt; -----------------------------------------</span>
    <span class="scan-line tool-line" data-line="2">&gt; email platform                <span class="found-tag">[FOUND]</span></span>
    <span class="scan-line tool-line" data-line="3">&gt; scheduling tool               <span class="found-tag">[FOUND]</span></span>
    <span class="scan-line tool-line" data-line="4">&gt; invoicing software            <span class="found-tag">[FOUND]</span></span>
    <span class="scan-line tool-line" data-line="5">&gt; payment processor             <span class="found-tag">[FOUND]</span></span>
    <span class="scan-line tool-line" data-line="6">&gt; social media scheduler        <span class="found-tag">[FOUND]</span></span>
    <span class="scan-line tool-line" data-line="7">&gt; CRM                           <span class="found-tag">[FOUND]</span></span>
    <span class="scan-line tool-line" data-line="8">&gt; project management tool       <span class="found-tag">[FOUND]</span></span>
    <span class="scan-line divider-line" data-line="9">&gt; -----------------------------------------</span>
    <span class="scan-line summary-line" data-line="10">&gt; TOOLS DETECTED:               <span class="stat-value">avg. 4 per day</span></span>
    <span class="scan-line summary-line" data-line="11">&gt; TOOLS DESIGNED TO WORK TOGETHER:         <span class="stat-value">0</span></span>
    <span class="scan-line summary-line" data-line="12">&gt; TIME LOST DAILY:              <span class="stat-value">~1.5 hrs</span></span>
    <span class="scan-line divider-line" data-line="13">&gt; -----------------------------------------</span>
    <span class="scan-line err-line" data-line="14">&gt; [ERR] NO_OPERATING_SYSTEM_DETECTED</span>
    <span class="scan-line err-line" data-line="15">&gt; [ERR] FRAGMENTATION_CONFIRMED</span>
    <div class="scan-cursor" aria-hidden="true"></div>
  </div>
  <p class="scan-source">// Slack / Salesforce, 2024 &middot; n=2,000</p>
  <p class="scan-caption">&ldquo;You didn&rsquo;t build a system. You built a pile of tools. Nobody designed the whole thing.&rdquo;</p>
</div>

<script>
  function initScanInfographic() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const infographics = document.querySelectorAll<HTMLElement>('[data-infographic]');

    infographics.forEach((el) => {
      if (prefersReducedMotion) {
        el.classList.add('revealed');
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              el.classList.add('revealed');
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.3 }
      );

      observer.observe(el);
    });
  }

  // Run on initial load and on Astro client-side navigation
  initScanInfographic();
  document.addEventListener('astro:after-swap', initScanInfographic);
</script>

<style>
  /* ── Container ── */
  .scan-infographic {
    max-width: 640px;
    width: 100%;
    margin: 0 auto;
    font-family: var(--font-mono);
    font-feature-settings: 'tnum' 1;
  }

  /* ── Terminal window ── */
  .scan-terminal {
    background: var(--crt-black);
    border: 1px solid var(--border-muted);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    overflow: hidden;
    position: relative;
  }

  /* ── All scan lines ── */
  .scan-line {
    display: block;
    white-space: pre;
    font-size: 0.8125rem;
    line-height: 1.7;
    will-change: clip-path;
    clip-path: inset(0 100% 0 0);
    opacity: 0;
  }

  /* ── Revealed state: lines animate in ── */
  .scan-infographic.revealed .scan-line {
    animation: scan-type-in 0.6s steps(20, end) forwards;
  }

  /* ── Line type colors ── */
  .prompt-line {
    color: var(--amber-3);
  }

  .divider-line {
    color: var(--amber-3);
  }

  .tool-line {
    color: var(--text-muted);
  }

  .found-tag {
    color: var(--amber-2);
  }

  .summary-line {
    color: var(--amber-2);
  }

  .stat-value {
    color: var(--amber-4);
  }

  .err-line {
    color: var(--danger);
  }

  /* ── Staggered animation delays ── */

  /* Line 0: SCANNING header — 0ms */
  .scan-infographic.revealed .scan-line[data-line="0"] {
    animation-delay: 0ms;
  }

  /* Line 1: first divider — 300ms */
  .scan-infographic.revealed .scan-line[data-line="1"] {
    animation-delay: 300ms;
  }

  /* Lines 2-8: tool lines — 80ms apart, starting at 600ms */
  .scan-infographic.revealed .scan-line[data-line="2"] {
    animation-delay: 600ms;
  }
  .scan-infographic.revealed .scan-line[data-line="3"] {
    animation-delay: 680ms;
  }
  .scan-infographic.revealed .scan-line[data-line="4"] {
    animation-delay: 760ms;
  }
  .scan-infographic.revealed .scan-line[data-line="5"] {
    animation-delay: 840ms;
  }
  .scan-infographic.revealed .scan-line[data-line="6"] {
    animation-delay: 920ms;
  }
  .scan-infographic.revealed .scan-line[data-line="7"] {
    animation-delay: 1000ms;
  }
  .scan-infographic.revealed .scan-line[data-line="8"] {
    animation-delay: 1080ms;
  }

  /* Line 9: second divider — 300ms gap after tools */
  .scan-infographic.revealed .scan-line[data-line="9"] {
    animation-delay: 1380ms;
  }

  /* Lines 10-12: summary stats — 300ms apart */
  .scan-infographic.revealed .scan-line[data-line="10"] {
    animation-delay: 1680ms;
  }
  .scan-infographic.revealed .scan-line[data-line="11"] {
    animation-delay: 1980ms;
  }
  .scan-infographic.revealed .scan-line[data-line="12"] {
    animation-delay: 2280ms;
  }

  /* Line 13: final divider */
  .scan-infographic.revealed .scan-line[data-line="13"] {
    animation-delay: 2580ms;
  }

  /* Lines 14-15: ERR lines — appear together after 600ms hold */
  .scan-infographic.revealed .scan-line[data-line="14"] {
    animation-delay: 3180ms;
  }
  .scan-infographic.revealed .scan-line[data-line="15"] {
    animation-delay: 3180ms;
  }

  /* ── Typing animation ── */
  @keyframes scan-type-in {
    from {
      clip-path: inset(0 100% 0 0);
      opacity: 1;
    }
    to {
      clip-path: inset(0 0 0 0);
      opacity: 1;
    }
  }

  /* ── Blinking cursor ── */
  .scan-cursor {
    display: inline-block;
    width: 0.55em;
    height: 1.1em;
    background: var(--amber-4);
    margin-top: 0.25rem;
    opacity: 0;
    vertical-align: text-bottom;
  }

  .scan-infographic.revealed .scan-cursor {
    animation: cursor-blink 533ms steps(1) infinite;
    /* Delay cursor until after the last line appears */
    animation-delay: 3780ms;
  }

  @keyframes cursor-blink {
    0%, 50% {
      opacity: 1;
    }
    51%, 100% {
      opacity: 0;
    }
  }

  /* ── Source caption ── */
  .scan-source {
    color: var(--text-accent-dim);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    margin-top: 0.75rem;
    line-height: 1.4;
  }

  /* ── Quote caption ── */
  .scan-caption {
    color: var(--amber-2);
    font-family: var(--font-mono);
    font-style: italic;
    font-size: 0.875rem;
    line-height: 1.5;
    margin-top: 1rem;
  }

  /* ── Reduced motion: show everything immediately ── */
  @media (prefers-reduced-motion: reduce) {
    .scan-line {
      clip-path: none;
      opacity: 1;
      will-change: auto;
      animation: none !important;
    }

    .scan-cursor {
      opacity: 1;
      animation: none !important;
    }
  }

  /* ── Mobile adjustments ── */
  @media (max-width: 767px) {
    .scan-terminal {
      padding: 1rem 1rem;
    }

    .scan-line {
      font-size: 0.6875rem;
      line-height: 1.6;
    }

    .scan-source {
      font-size: 0.625rem;
    }

    .scan-caption {
      font-size: 0.8125rem;
    }
  }
</style>
