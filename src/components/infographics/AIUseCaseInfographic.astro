---
// No imports needed — pure Astro component
---

<div class="ai-infographic" data-infographic>
  <div class="ai-terminal">
    <p class="ai-comment">// AVERAGE TIME SAVED PER WEEK (small businesses using AI)</p>

    <div class="hero-stat">
      <span class="hero-number">5</span>
      <span class="hero-unit">HRS / WEEK</span>
    </div>

    <p class="ai-comment">// WHAT SMALL BUSINESSES ACTUALLY USE IT FOR</p>

    <div class="bar-chart">
      <div class="bar-row">
        <span class="bar-label">MARKETING CONTENT</span>
        <div class="bar-track">
          <div class="bar-fill" style="--target-width: 43%"></div>
        </div>
        <span class="bar-pct">43%</span>
      </div>

      <div class="bar-row">
        <span class="bar-label">CUSTOMER SERVICE</span>
        <div class="bar-track">
          <div class="bar-fill" style="--target-width: 36%"></div>
        </div>
        <span class="bar-pct">36%</span>
      </div>

      <div class="bar-row">
        <span class="bar-label">ADMIN TASKS</span>
        <div class="bar-track">
          <div class="bar-fill" style="--target-width: 33%"></div>
        </div>
        <span class="bar-pct">33%</span>
      </div>

      <div class="bar-row">
        <span class="bar-label">DATA QUESTIONS</span>
        <div class="bar-track">
          <div class="bar-fill" style="--target-width: 32%"></div>
        </div>
        <span class="bar-pct">32%</span>
      </div>
    </div>

    <div class="ai-sources">
      <p class="ai-comment">// QuickBooks, 2025 &middot; n=2,200 &middot; Google, 2025</p>
      <p class="ai-ok-line"><span class="badge-ok">[OK]</span> NONE OF THIS REQUIRES A DATA SCIENTIST</p>
    </div>
  </div>

  <p class="ai-caption">"AI isn't a platform you learn. It's a task you stop doing by hand."</p>
</div>

<script>
  function initInfographic() {
    const infographics = document.querySelectorAll<HTMLElement>('[data-infographic]');

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    infographics.forEach((el) => {
      if (prefersReducedMotion) {
        el.classList.add('revealed');
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.3 }
      );

      observer.observe(el);
    });
  }

  // Run on initial load
  initInfographic();

  // Re-run after Astro client-side navigation (View Transitions)
  document.addEventListener('astro:page-load', initInfographic);
</script>

<style>
  /* ── Container ── */
  .ai-infographic {
    max-width: 560px;
    width: 100%;
    font-family: var(--font-mono);
    font-feature-settings: 'tnum' 1;
  }

  /* ── Terminal frame ── */
  .ai-terminal {
    background: var(--crt-black);
    border: 1px solid var(--border-muted);
    border-radius: 4px;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ── Comment lines ── */
  .ai-comment {
    color: var(--amber-2);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.4;
    margin: 0;
  }

  /* ── Hero stat ── */
  .hero-stat {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-2) 0;
  }

  .hero-number {
    color: var(--amber-4);
    font-family: var(--font-sans);
    font-size: var(--step-3, 48px);
    font-weight: 700;
    line-height: 1;
  }

  .hero-unit {
    color: var(--amber-4);
    font-family: var(--font-sans);
    font-size: var(--step-0, 18px);
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  /* ── Bar chart ── */
  .bar-chart {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .bar-row {
    display: grid;
    grid-template-columns: 160px 1fr 44px;
    align-items: center;
    gap: var(--space-3);
  }

  .bar-label {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
    white-space: nowrap;
  }

  .bar-track {
    background: var(--bg-elevated);
    height: 20px;
    border-radius: 2px;
    overflow: hidden;
  }

  .bar-fill {
    width: var(--target-width);
    height: 100%;
    background: var(--success);
    border-radius: 2px;
    transform-origin: left;
    transform: scaleX(0);
    will-change: transform;
  }

  .bar-pct {
    color: var(--amber-4);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    text-align: right;
    opacity: 0;
  }

  /* ── Sources & OK line ── */
  .ai-sources {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .ai-sources .ai-comment {
    font-size: 11px;
    color: var(--text-accent-dim);
  }

  .ai-ok-line {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
    margin: 0;
    opacity: 0;
  }

  .badge-ok {
    color: var(--success);
    font-weight: 700;
  }

  /* ── Caption ── */
  .ai-caption {
    color: var(--amber-2);
    font-family: var(--font-mono);
    font-style: italic;
    font-size: 13px;
    text-align: center;
    margin: var(--space-4) 0 0;
    line-height: 1.5;
  }

  /* ─────────────────────────────────────
     ANIMATION — Revealed state
     ───────────────────────────────────── */

  /* Hero stat: fade + scale up over 800ms with deceleration */
  .hero-number,
  .hero-unit {
    opacity: 0;
    transform: scale(0.7);
    transition: none;
  }

  .ai-infographic.revealed .hero-number,
  .ai-infographic.revealed .hero-unit {
    opacity: 1;
    transform: scale(1);
    transition:
      opacity 800ms cubic-bezier(0.0, 0.0, 0.2, 1),
      transform 800ms cubic-bezier(0.0, 0.0, 0.2, 1);
  }

  /* Bars fill after hero stat (800ms delay), 600ms duration */
  .ai-infographic.revealed .bar-fill {
    transform: scaleX(1);
    transition: transform 600ms cubic-bezier(0.0, 0.0, 0.2, 1) 800ms;
  }

  /* Percentage labels appear after bars finish (800 + 600 = 1400ms) */
  .ai-infographic.revealed .bar-pct {
    opacity: 1;
    transition: opacity 300ms ease 1400ms;
  }

  /* OK line fades in 300ms after bars complete (1400 + 300 = 1700ms) */
  .ai-infographic.revealed .ai-ok-line {
    opacity: 1;
    transition: opacity 300ms ease 1700ms;
  }

  /* ─────────────────────────────────────
     REDUCED MOTION — Everything visible
     ───────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero-number,
    .hero-unit {
      opacity: 1;
      transform: scale(1);
    }

    .bar-fill {
      transform: scaleX(1);
    }

    .bar-pct {
      opacity: 1;
    }

    .ai-ok-line {
      opacity: 1;
    }
  }

  /* ─────────────────────────────────────
     RESPONSIVE — Mobile (< 768px)
     ───────────────────────────────────── */
  @media (max-width: 767px) {
    .ai-terminal {
      padding: var(--space-4);
    }

    .hero-number {
      font-size: var(--step-2, 36px);
    }

    .hero-unit {
      font-size: var(--step--1, 15px);
    }

    .bar-row {
      grid-template-columns: 1fr 44px;
      grid-template-rows: auto auto;
      gap: var(--space-1) var(--space-3);
    }

    .bar-label {
      grid-column: 1 / -1;
    }

    .bar-track {
      height: 16px;
    }

    .ai-caption {
      font-size: 12px;
    }
  }
</style>
