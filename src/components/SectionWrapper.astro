---
interface Props {
  id?: string;
  bg?: 'dark' | 'base' | 'light';
  class?: string;
}
const { id, bg = 'dark', class: className } = Astro.props;
const bgMap = {
  dark: 'var(--bg-dark)',
  base: 'var(--bg)',
  light: 'var(--bg-light)'
};
---
<section id={id} class:list={['section-wrap', 'reveal', className]} style={`background: ${bgMap[bg]};`}>
  <div class="section-inner">
    <slot />
  </div>
</section>

<style>
  .section-wrap {
    padding: var(--space-20) var(--space-8);
    overflow: hidden;
  }
  .section-inner {
    max-width: var(--container-xl);
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .section-wrap {
      padding: var(--space-12) var(--space-6);
    }
  }
</style>
