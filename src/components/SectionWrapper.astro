---
interface Props {
  id?: string;
  theme?: 'dark' | 'light' | 'amber';
  /** @deprecated Use `theme` instead. Kept for backward compatibility. */
  bg?: 'dark' | 'base' | 'light';
  class?: string;
  overflow?: 'hidden' | 'visible';
}
const { id, theme, bg, class: className, overflow = 'hidden' } = Astro.props;

/* New `theme` prop takes priority; old `bg` prop maps to closest theme */
const bgToTheme: Record<string, 'dark' | 'light' | 'amber'> = {
  dark: 'dark',
  base: 'dark',
  light: 'light',
};
const resolvedTheme = theme ?? (bg ? bgToTheme[bg] : 'dark');
---
<section
  id={id}
  class:list={['section-wrap', `theme-${resolvedTheme}`, className]}
  style={`overflow: ${overflow};`}
>
  <div class="section-inner">
    <slot />
  </div>
</section>

<style>
  .section-wrap {
    padding: var(--space-16) var(--space-8); /* 64px — brand spec section vertical */
  }
  .section-inner {
    max-width: var(--container-xl);
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .section-wrap {
      padding: var(--space-10) var(--space-6); /* 40px vertical, 24px horizontal */
    }
  }
</style>
