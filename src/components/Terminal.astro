---
interface Props {
  title?: string;
  class?: string;
}
const { title, class: className } = Astro.props;
---
<div class:list={['terminal', className]}>
  <div class="terminal-bar">
    <span class="dot r"></span>
    <span class="dot y"></span>
    <span class="dot g"></span>
    {title && <span class="terminal-title">{title}</span>}
  </div>
  <div class="terminal-body">
    <slot />
  </div>
</div>

<style>
  .terminal {
    background: var(--bg-dark);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-sm);
    padding: var(--space-8);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-feature-settings: 'tnum' 1;
    color: var(--text);
    overflow: hidden;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-muted);
  }
  .terminal-title {
    font-size: var(--step--2);
    color: var(--text-muted);
    margin-left: var(--space-2);
    letter-spacing: 0.06em;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot.r { background: var(--danger); box-shadow: 0 0 6px var(--danger); }
  .dot.y { background: var(--warning); box-shadow: 0 0 6px var(--warning); }
  .dot.g { background: var(--success); box-shadow: 0 0 6px var(--success); }
  .terminal-body {
    line-height: 1.7;
  }
</style>
