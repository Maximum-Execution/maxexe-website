---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<div class:list={['card-glass', className]}>
  <slot />
</div>

<style>
  .card-glass {
    background: oklch(0.18 0.09 62 / 0.55);
    backdrop-filter: blur(16px) saturate(1.3);
    -webkit-backdrop-filter: blur(16px) saturate(1.3);
    border: 1px solid oklch(0.40 0.18 62 / 0.25);
    box-shadow: inset 0 1px 0 oklch(0.60 0.18 62 / 0.12);
    border-radius: var(--radius-md);
    padding: var(--space-8);
  }
</style>
